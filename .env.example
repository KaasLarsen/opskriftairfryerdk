# Kopier til .env (lokalt) og udfyld fra Supabase: Project Settings → API.
# Indsæt samme variabler hos din host (fx Vercel → Environment Variables).
# Brug KUN anon/public key her – aldrig service_role.

PUBLIC_SUPABASE_URL=https://dit-projekt.supabase.co
PUBLIC_SUPABASE_ANON_KEY=erstat-med-anon-key-fra-supabase
