{
	"trailingSlash": false,
	"redirects": [
		{
			"source": "/index.html",
			"destination": "/",
			"permanent": true
		},
		{
			"source": "/opskrifter/:slug.html",
			"destination": "/opskrifter/:slug",
			"permanent": true
		},
		{
			"source": "/:page.html",
			"destination": "/:page",
			"permanent": true
		}
	]
}
