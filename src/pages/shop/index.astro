---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShopProductCard from '../../components/ShopProductCard.astro';
import { SITE_NAME } from '../../consts';
import {
	type ShopProductJson,
	pickFeaturedShopProducts,
	SHOP_FEATURED_ACCESSORY_LIMIT,
	SHOP_FEATURED_AIRFRYER_LIMIT,
} from '../../data/shop-curation';
import fs from 'node:fs';
import path from 'node:path';

const fp = path.join(process.cwd(), 'public/data/shop-products.json');
let allProducts: ShopProductJson[] = [];
if (fs.existsSync(fp)) {
	try {
		const data = JSON.parse(fs.readFileSync(fp, 'utf8')) as { products?: ShopProductJson[] };
		allProducts = Array.isArray(data.products) ? data.products : [];
	} catch {
		allProducts = [];
	}
}

const airfryers = pickFeaturedShopProducts(allProducts, 'airfryer', SHOP_FEATURED_AIRFRYER_LIMIT);
const accessories = pickFeaturedShopProducts(
	allProducts,
	'accessory',
	SHOP_FEATURED_ACCESSORY_LIMIT,
);

const title = `Shop – airfryere og tilbehør | ${SITE_NAME}`;
const description =
	'Find airfryere og praktisk tilbehør til din airfryer. Udvalg af produkter med vejledende priser — se altid aktuel pris hos forhandleren.';
---

<BaseLayout title={title} description={description} canonicalPath="/shop" ogType="website">
	<section class="section section--tight-top">
		<div class="container">
			<nav class="recipe-breadcrumbs" aria-label="Brødkrummer">
				<a href="/">Forside</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<span class="recipe-breadcrumbs-current">Shop</span>
			</nav>

			<div class="section-head shop-section-head">
				<p class="section-kicker">Shop</p>
				<h1 class="recipe-title">Airfryere og tilbehør</h1>
				<p>
					Her samler vi gode bud på airfryere og tilbehør, så du nemt kan sammenligne og gå videre
					hos forhandleren. Priser og lager kan ændre sig — tjek altid hos butikken før du køber.
				</p>
			</div>

			<div class="shop-partner-banner" role="region" aria-label="Partnerannonce">
				<a
					href="https://www.partner-ads.com/dk/klikbanner.php?partnerid=52794&bannerid=104110"
					target="_blank"
					rel="nofollow noopener noreferrer sponsored"
					class="shop-partner-banner-link"
				>
					<img
						src="https://www.partner-ads.com/dk/visbanner.php?partnerid=52794&bannerid=104110"
						width="728"
						height="90"
						alt="GrydeGuru — tilbud via partner (åbner hos forhandler)"
						class="shop-partner-banner-img"
						loading="eager"
						decoding="async"
					/>
				</a>
				<p class="shop-partner-banner-caption">Annonce — linket fører til vores samarbejdspartner.</p>
			</div>

			<div class="shop-search-panel" data-shop-page>
				<label class="sr-only" for="shop-search-input">Søg i produkter</label>
				<input
					id="shop-search-input"
					class="shop-search-input"
					type="search"
					placeholder="Søg efter produkt, brand eller kategori…"
					autocomplete="off"
					spellcheck="false"
				/>
				<div class="shop-chip-row" role="group" aria-label="Afgræns søgning">
					<button type="button" class="shop-chip shop-chip--active" data-shop-scope="all">
						Alle
					</button>
					<button type="button" class="shop-chip" data-shop-scope="airfryer">Airfryere</button>
					<button type="button" class="shop-chip" data-shop-scope="accessory">Tilbehør</button>
				</div>
				<div class="shop-filters" data-shop-filters hidden>
					<p class="shop-filters-title">Flere filtre</p>
					<div class="shop-filters-grid">
						<div class="shop-filter-field">
							<label for="shop-price-min">Pris min (kr)</label>
							<input
								type="number"
								id="shop-price-min"
								class="shop-filter-input"
								min="0"
								step="1"
								placeholder="Fx 500"
							/>
						</div>
						<div class="shop-filter-field">
							<label for="shop-price-max">Pris max (kr)</label>
							<input
								type="number"
								id="shop-price-max"
								class="shop-filter-input"
								min="0"
								step="1"
								placeholder="Fx 2500"
							/>
						</div>
						<div class="shop-filter-field">
							<label for="shop-cap-min">Kurv min (liter)</label>
							<input
								type="number"
								id="shop-cap-min"
								class="shop-filter-input"
								min="0"
								step="0.1"
								placeholder="Fx 4"
							/>
						</div>
						<div class="shop-filter-field">
							<label for="shop-cap-max">Kurv max (liter)</label>
							<input
								type="number"
								id="shop-cap-max"
								class="shop-filter-input"
								min="0"
								step="0.1"
								placeholder="Fx 8"
							/>
						</div>
						<div class="shop-filter-field shop-filter-field--wide">
							<label for="shop-color-filter">Farve</label>
							<input
								type="search"
								id="shop-color-filter"
								class="shop-filter-input"
								placeholder="Fx sort, hvid, stål…"
								autocomplete="off"
							/>
						</div>
					</div>
					<details class="shop-brand-details">
						<summary class="shop-brand-summary">
							Mærke
							<span class="shop-brand-summary-hint">Fold ud for at vælge</span>
						</summary>
						<div id="shop-brand-boxes" class="shop-brand-boxes"></div>
					</details>
					<button type="button" class="shop-filter-reset" id="shop-filter-reset">Nulstil filtre</button>
				</div>
				<p class="shop-search-hint" data-shop-hint>
					Søg eller brug filtre ovenfor (pris, kurvstørrelse, farve, mærke) — listen opdateres ved hvert
					build.
				</p>
				<div id="shop-search-results" class="recipe-grid shop-search-results" hidden></div>
			</div>
		</div>
	</section>

	{
		airfryers.length > 0 && (
			<section class="section section--tight-top" id="udvalgte-airfryere" aria-labelledby="shop-af-heading">
				<div class="container">
					<div class="section-head">
						<p class="section-kicker">Udvalg</p>
						<h2 id="shop-af-heading">Udvalgte airfryere</h2>
						<p>
							Udvalgt på tværs af flere butikker, så du får bredt spredning — der findes flere via
							søgningen.
						</p>
					</div>
					<div class="recipe-grid">
						{airfryers.map((p) => (
							<ShopProductCard
								title={p.title}
								brand={p.brand}
								category={p.category}
								retailer={p.retailer}
								price={p.price}
								listPrice={p.listPrice}
								imageUrl={p.imageUrl}
								productUrl={p.productUrl}
							/>
						))}
					</div>
				</div>
			</section>
		)
	}

	{
		accessories.length > 0 && (
			<section class="section section--tight-top" id="udvalgte-tilbehor" aria-labelledby="shop-acc-heading">
				<div class="container">
					<div class="section-head">
						<p class="section-kicker">Udvalg</p>
						<h2 id="shop-acc-heading">Udvalgt tilbehør</h2>
						<p>
							Udvalgt tilbehør fra flere kilder — kurve, forme, indsatser og lignende til din
							airfryer.
						</p>
					</div>
					<div class="recipe-grid">
						{accessories.map((p) => (
							<ShopProductCard
								title={p.title}
								brand={p.brand}
								category={p.category}
								retailer={p.retailer}
								price={p.price}
								listPrice={p.listPrice}
								imageUrl={p.imageUrl}
								productUrl={p.productUrl}
							/>
						))}
					</div>
				</div>
			</section>
		)
	}

	{
		allProducts.length === 0 && (
			<section class="section section--tight-top">
				<div class="container">
					<div class="shop-empty-state">
						<p>
							Der er ingen produkter i shoppen lige nu — udvalget fyldes op igen, så snart der er nyt
							at vise.
						</p>
					</div>
				</div>
			</section>
		)
	}
</BaseLayout>

<script src="/shop-page.js" defer></script>
