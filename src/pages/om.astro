---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME } from '../consts';

const description = `Læs mere om ${SITE_NAME} og idéen bag opskrifterne.`;
---

<BaseLayout
	title={`Om ${SITE_NAME}`}
	{description}
	canonicalPath="/om"
>
	<section class="section" style="padding-top: var(--space-12)">
		<div class="container prose">
			<h1 class="recipe-title">Om {SITE_NAME}</h1>
			<p>
				Vi samler <strong>praktiske airfryer-opskrifter</strong> til hverdagen – med nogle få,
				klare trin og realistiske tider, så det er nemt at lykkes.
			</p>
			<p>
				Målet er, at du hurtigt kan finde ud af, hvad du skal gøre, og få mad på bordet uden
				detaljer, der kun er til for syns skyld.
			</p>
			<p>
				Har du spørgsmål eller vil du sige hej?
				<a href="/kontakt">Skriv via kontakt</a>.
			</p>
		</div>
	</section>
</BaseLayout>
