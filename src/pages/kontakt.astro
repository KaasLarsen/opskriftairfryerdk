---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_EMAIL, SITE_NAME } from '../consts';

const description = `Kontakt ${SITE_NAME}.`;
---

<BaseLayout
	title={`Kontakt | ${SITE_NAME}`}
	{description}
	canonicalPath="/kontakt"
>
	<section class="section section--tight-top">
		<div class="container prose">
			<h1 class="recipe-title">Kontakt</h1>
			<p>
				Du er velkommen til at skrive, hvis du har spørgsmål, forslag eller finder noget, der
				skal rettes.
			</p>
			<p>
				<strong>E-mail:</strong>
				<a href={`mailto:${SITE_EMAIL}`}>{SITE_EMAIL}</a>
			</p>
		</div>
	</section>
</BaseLayout>
