---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { ORGANIZATION_JSON, SITE_NAME, SITE_URL } from '../../consts';
import { isoDurationFromMinutes, toAbsoluteUrl } from '../../utils/seo';

export async function getStaticPaths() {
	const recipes = await getCollection('recipes');
	return recipes.map((recipe) => ({
		params: { slug: recipe.id },
		props: { recipe },
	}));
}

interface Props {
	recipe: CollectionEntry<'recipes'>;
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const d = recipe.data;
const site = Astro.site;

if (!site) {
	throw new Error('Konfigurer site i astro.config.mjs (site: https://opskriftairfryer.dk)');
}

const canonicalPath = `/opskrifter/${recipe.id}`;
const pageUrl = new URL(canonicalPath, site).toString();
const absImage = d.heroImage
	? toAbsoluteUrl(site, d.heroImage)
	: new URL('/og-default.svg', site).toString();

const totalMinutes = d.prepMinutes + d.cookMinutes;

function splitParagraphs(text: string | undefined): string[] {
	if (!text?.trim()) return [];
	return text
		.split(/\n\s*\n/)
		.map((p) => p.trim())
		.filter(Boolean);
}

const introParagraphs = splitParagraphs(d.intro);
const conclusionParagraphs = splitParagraphs(d.conclusion);

const recipeJson: Record<string, unknown> = {
	'@type': 'Recipe',
	'@id': `${pageUrl}#recipe`,
	name: d.title,
	description: d.description,
	image: [absImage],
	author: {
		'@type': 'Organization',
		name: SITE_NAME,
		url: SITE_URL,
	},
	datePublished: d.pubDate.toISOString(),
	dateModified: (d.updatedDate ?? d.pubDate).toISOString(),
	prepTime: isoDurationFromMinutes(d.prepMinutes),
	cookTime: isoDurationFromMinutes(d.cookMinutes),
	totalTime: isoDurationFromMinutes(totalMinutes),
	recipeYield: d.servings,
	recipeCategory: d.category,
	recipeCuisine: d.cuisine,
	keywords: d.keywords.join(', '),
	recipeIngredient: d.ingredients.map((i) => i.text),
	recipeInstructions: d.instructions.map((step, idx) => ({
		'@type': 'HowToStep',
		position: idx + 1,
		text: step.text,
	})),
};

if (d.temperatureC) {
	recipeJson.cookingMethod = 'Airfryer';
}

if (d.calories) {
	recipeJson.nutrition = {
		'@type': 'NutritionInformation',
		calories: d.calories,
	};
}

const breadcrumbJson = {
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Forside',
			item: new URL('/', site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Opskrifter',
			item: new URL('/opskrifter', site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: d.title,
			item: pageUrl,
		},
	],
};

const faqJson =
	d.faq && d.faq.length > 0
		? {
				'@type': 'FAQPage',
				mainEntity: d.faq.map((f) => ({
					'@type': 'Question',
					name: f.question,
					acceptedAnswer: { '@type': 'Answer', text: f.answer },
				})),
			}
		: null;

const jsonLdGraph: Record<string, unknown>[] = [
	ORGANIZATION_JSON as Record<string, unknown>,
	recipeJson,
	breadcrumbJson,
	...(faqJson ? [faqJson] : []),
];

const others = (await getCollection('recipes'))
	.filter((r) => r.id !== recipe.id)
	.slice(0, 3);

const articleLd = {
	'@type': 'Article',
	headline: d.title,
	description: d.description,
	image: [absImage],
	datePublished: d.pubDate.toISOString(),
	dateModified: (d.updatedDate ?? d.pubDate).toISOString(),
	author: { '@id': `${SITE_URL}/#organization` },
	publisher: { '@id': `${SITE_URL}/#organization` },
	mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
};

const jsonLdWithArticle = [...jsonLdGraph, articleLd];
---

<BaseLayout
	title={d.title}
	description={d.description}
	canonicalPath={canonicalPath}
	ogImage={d.heroImage ? absImage : undefined}
	ogType="article"
	jsonLd={jsonLdWithArticle}
>
	<article class="section recipe-article">
		<div class="container recipe-article-inner">
			<nav class="recipe-breadcrumbs" aria-label="Brødkrummer">
				<a href="/">Forside</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<a href="/opskrifter">Opskrifter</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<span class="recipe-breadcrumbs-current">{d.title}</span>
			</nav>

			<div class="recipe-hero">
				<div
					class:list={[
						'recipe-hero-img',
						!d.heroImage && 'recipe-hero-img--placeholder',
					]}
				>
					{
						d.heroImage ? (
							<img
								src={d.heroImage}
								alt={d.heroAlt ?? d.title}
								width="1200"
								height="900"
								fetchpriority="high"
								decoding="async"
							/>
						) : (
							<div
								class="recipe-placeholder-inner"
								role="img"
								aria-label="Billede til opskriften kommer snart"
							>
								<span class="recipe-placeholder-label">Billede på vej</span>
							</div>
						)
					}
				</div>
				<div class="recipe-hero-copy">
					<h1 class="recipe-title">{d.title}</h1>
					<div class="recipe-meta-panel" role="group" aria-label="Tider og mængder">
						<div class="recipe-meta-cell">
							<span class="recipe-meta-label">Forberedelse</span>
							<span class="recipe-meta-value">{d.prepMinutes} min</span>
						</div>
						<div class="recipe-meta-cell">
							<span class="recipe-meta-label">Tilberedning</span>
							<span class="recipe-meta-value">{d.cookMinutes} min</span>
						</div>
						<div class="recipe-meta-cell">
							<span class="recipe-meta-label">I alt</span>
							<span class="recipe-meta-value">{totalMinutes} min</span>
						</div>
						<div class="recipe-meta-cell recipe-meta-cell--wide">
							<span class="recipe-meta-label">Portioner</span>
							<span class="recipe-meta-value">{d.servings}</span>
						</div>
						{
							d.temperatureC !== undefined && (
								<div class="recipe-meta-cell">
									<span class="recipe-meta-label">Airfryer</span>
									<span class="recipe-meta-value">{d.temperatureC} °C</span>
								</div>
							)
						}
					</div>
					<p class="recipe-lead">{d.description}</p>
				</div>
			</div>

			{
				introParagraphs.length > 0 && (
					<section
						class="recipe-section recipe-intro-block"
						aria-labelledby="recipe-intro-heading"
					>
						<h2 id="recipe-intro-heading" class="block-title recipe-block-title">
							Indledning
						</h2>
						<div class="recipe-rich-text">
							{introParagraphs.map((p) => (
								<p>{p}</p>
							))}
						</div>
					</section>
				)
			}

			<div class="two-col recipe-body-columns">
				<section class="recipe-block" aria-labelledby="ingredients-heading">
					<h2 id="ingredients-heading" class="block-title recipe-block-title">Ingredienser</h2>
					<div class="recipe-card-panel">
						<ul class="recipe-panel-list">
							{d.ingredients.map((ing) => (
								<li>
									<span class="recipe-panel-text">{ing.text}</span>
								</li>
							))}
						</ul>
					</div>
				</section>
				<section class="recipe-block" aria-labelledby="steps-heading">
					<h2 id="steps-heading" class="block-title recipe-block-title">Sådan gør du</h2>
					<div class="recipe-steps-panel">
						<ul class="step-list">
						{
							d.instructions.map((step, idx) => (
								<li>
									<span class="step-num">{idx + 1}</span>
									<span class="step-text">{step.text}</span>
								</li>
							))
						}
					</ul>
					</div>
				</section>
			</div>

			{
				d.tips && d.tips.length > 0 && (
					<section class="recipe-block recipe-block--tips" aria-labelledby="tips-heading">
						<h2 id="tips-heading" class="block-title recipe-block-title">
							Eksperttips
						</h2>
						<div class="recipe-card-panel recipe-card-panel--tips">
							<ul class="recipe-panel-list recipe-panel-list--tips">
								{d.tips.map((t) => (
									<li>
										<span class="recipe-panel-text">{t}</span>
									</li>
								))}
							</ul>
						</div>
					</section>
				)
			}

			<section class="prose recipe-prose">
				<h2 class="block-title recipe-block-title">Baggrund og servering</h2>
				<Content />
			</section>

			{
				conclusionParagraphs.length > 0 && (
					<section
						class="recipe-section recipe-conclusion-block"
						aria-labelledby="recipe-conclusion-heading"
					>
						<h2 id="recipe-conclusion-heading" class="block-title recipe-block-title">
							Konklusion
						</h2>
						<div class="recipe-rich-text">
							{conclusionParagraphs.map((p) => (
								<p>{p}</p>
							))}
						</div>
					</section>
				)
			}

			{
				d.faq && d.faq.length > 0 && (
					<section class="faq recipe-faq" aria-labelledby="faq-heading">
						<h2 id="faq-heading" class="block-title recipe-block-title">
							Ofte stillede spørgsmål
						</h2>
						{d.faq.map((item) => (
							<details>
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						))}
					</section>
				)
			}

			<section class="related-grid recipe-related" aria-labelledby="related-heading">
				<h2 id="related-heading" class="block-title recipe-block-title">Prøv også</h2>
				<div class="recipe-grid">
					{others.map((r) => (
						<RecipeCard recipe={r} />
					))}
				</div>
				<p class="recipe-back-link">
					<a href="/opskrifter">Tilbage til alle opskrifter</a>
				</p>
			</section>
		</div>
	</article>
</BaseLayout>
