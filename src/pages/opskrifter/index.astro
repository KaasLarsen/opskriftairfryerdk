---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getCollection } from 'astro:content';
import { SITE_NAME, SITE_URL } from '../../consts';

const recipes = (await getCollection('recipes')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const title = `Alle airfryer-opskrifter`;
const description =
	'Oversigt over airfryer-opskrifter til hverdagen – kylling, fisk, kartofler, grønt og mere. Tydelige tider og temperaturer.';

const jsonLd = {
	'@type': 'ItemList',
	itemListElement: recipes.map((r, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		url: new URL(`/opskrifter/${r.id}`, Astro.site ?? SITE_URL).toString(),
		name: r.data.title,
	})),
};
---

<BaseLayout
	title={`${title} | ${SITE_NAME}`}
	{description}
	canonicalPath="/opskrifter"
	jsonLd={jsonLd}
>
	<section class="section" style="padding-top: var(--space-12)">
		<div class="container">
			<div class="section-head">
				<p class="section-kicker">Opskrifter</p>
				<h1>Alle airfryer-opskrifter</h1>
				<p>
					Hurtige idéer til travle dage – find noget, der passer til din airfryer og din tid.
				</p>
			</div>
			<div class="recipe-grid">
				{recipes.map((recipe) => <RecipeCard recipe={recipe} />)}
			</div>
		</div>
	</section>
</BaseLayout>
