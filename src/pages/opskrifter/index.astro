---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getCollection } from 'astro:content';
import { SITE_NAME, SITE_URL } from '../../consts';

const recipes = (await getCollection('recipes')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function inferSeason(recipe: (typeof recipes)[number]): string {
	const haystack = [recipe.data.title, recipe.data.category, ...recipe.data.keywords]
		.join(' ')
		.toLowerCase();
	if (/(påske|lam|skinke|asparges)/.test(haystack)) return 'påske';
	if (/(jul|and|flæskesteg|ribbensteg)/.test(haystack)) return 'jul';
	if (/(grill|sommer|salat)/.test(haystack)) return 'sommer';
	return 'hele-året';
}

const categories = [...new Set(recipes.map((r) => r.data.category))].sort((a, b) =>
	a.localeCompare(b, 'da'),
);

const title = `Alle airfryer-opskrifter`;
const description =
	'Oversigt over airfryer-opskrifter til hverdagen – kylling, fisk, kartofler, grønt og mere. Tydelige tider og temperaturer.';

const jsonLd = {
	'@type': 'ItemList',
	itemListElement: recipes.map((r, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		url: new URL(`/opskrifter/${r.id}`, Astro.site ?? SITE_URL).toString(),
		name: r.data.title,
	})),
};
---

<BaseLayout
	title={`${title} | ${SITE_NAME}`}
	{description}
	canonicalPath="/opskrifter"
	jsonLd={jsonLd}
>
	<section class="section section--tight-top">
		<div class="container">
			<div class="section-head">
				<p class="section-kicker">Opskrifter</p>
				<h1>Alle airfryer-opskrifter</h1>
				<p>
					Hurtige idéer til travle dage – find noget, der passer til din airfryer og din tid.
				</p>
			</div>
			<div class="filter-links">
				<a href="/opskrifter/saeson/paaske">Se alle Påske-opskrifter</a>
			</div>
			<div class="recipe-filters" aria-label="Filtrer opskrifter">
				<label>
					Kategori
					<select id="filter-category" class="filter-select">
						<option value="">Alle kategorier</option>
						{categories.map((category) => <option value={category}>{category}</option>)}
					</select>
				</label>
				<label>
					Sæson
					<select id="filter-season" class="filter-select">
						<option value="">Alle sæsoner</option>
						<option value="påske">Påske</option>
						<option value="jul">Jul</option>
						<option value="sommer">Sommer</option>
						<option value="hele-året">Hele året</option>
					</select>
				</label>
				<label>
					Maks tid
					<select id="filter-max-time" class="filter-select">
						<option value="">Alle tider</option>
						<option value="20">Under 20 min</option>
						<option value="30">Under 30 min</option>
						<option value="45">Under 45 min</option>
					</select>
				</label>
				<button id="filter-reset" type="button" class="btn btn-ghost filter-reset-btn">Nulstil</button>
			</div>
			<p id="filter-count" class="filter-count" aria-live="polite">
				Viser {recipes.length} opskrifter
			</p>
			<p id="filter-empty" class="filter-empty" hidden>Ingen opskrifter matcher dine filtre endnu.</p>
			<div class="recipe-grid" id="recipes-grid">
				{
					recipes.map((recipe) => (
						<div
							class="filter-item"
							data-category={recipe.data.category}
							data-season={inferSeason(recipe)}
							data-total-minutes={recipe.data.prepMinutes + recipe.data.cookMinutes}
						>
							<RecipeCard recipe={recipe} />
						</div>
					))
				}
			</div>
			<div class="load-more-wrap">
				<button id="load-more" type="button" class="btn btn-secondary">Vis flere</button>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	const category = document.getElementById('filter-category');
	const season = document.getElementById('filter-season');
	const maxTime = document.getElementById('filter-max-time');
	const reset = document.getElementById('filter-reset');
	const count = document.getElementById('filter-count');
	const empty = document.getElementById('filter-empty');
	const loadMore = document.getElementById('load-more');
	const items = Array.from(document.querySelectorAll('.filter-item'));
	const INITIAL_VISIBLE = 30;
	const STEP_VISIBLE = 12;
	let visibleLimit = INITIAL_VISIBLE;

	function updateUrl() {
		const params = new URLSearchParams(window.location.search);
		const selectedCategory = category instanceof HTMLSelectElement ? category.value : '';
		const selectedSeason = season instanceof HTMLSelectElement ? season.value : '';
		const selectedMaxTime = maxTime instanceof HTMLSelectElement ? maxTime.value : '';

		if (selectedCategory) params.set('kategori', selectedCategory);
		else params.delete('kategori');

		if (selectedSeason) params.set('saeson', selectedSeason);
		else params.delete('saeson');

		if (selectedMaxTime) params.set('maxTid', selectedMaxTime);
		else params.delete('maxTid');

		const qs = params.toString();
		const nextUrl = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
		window.history.replaceState({}, '', nextUrl);
	}

	function hydrateFromUrl() {
		const params = new URLSearchParams(window.location.search);
		const kategori = params.get('kategori');
		const saeson = params.get('saeson');
		const maxTid = params.get('maxTid');

		if (kategori && category instanceof HTMLSelectElement) category.value = kategori;
		if (saeson && season instanceof HTMLSelectElement) season.value = saeson;
		if (maxTid && maxTime instanceof HTMLSelectElement) maxTime.value = maxTid;
	}

	function applyFilters(resetVisibleLimit = false) {
		if (resetVisibleLimit) visibleLimit = INITIAL_VISIBLE;
		const selectedCategory = category instanceof HTMLSelectElement ? category.value : '';
		const selectedSeason = season instanceof HTMLSelectElement ? season.value : '';
		const selectedMaxTime =
			maxTime instanceof HTMLSelectElement && maxTime.value ? Number(maxTime.value) : NaN;

		const matched = [];
		for (const item of items) {
			const itemCategory = item.getAttribute('data-category') ?? '';
			const itemSeason = item.getAttribute('data-season') ?? '';
			const itemTotalMinutes = Number(item.getAttribute('data-total-minutes') ?? '0');

			const matchCategory = !selectedCategory || itemCategory === selectedCategory;
			const matchSeason = !selectedSeason || itemSeason === selectedSeason;
			const matchTime = Number.isNaN(selectedMaxTime) || itemTotalMinutes <= selectedMaxTime;

			const isMatch = matchCategory && matchSeason && matchTime;
			if (isMatch) matched.push(item);
		}

		for (const item of items) item.hidden = true;
		for (const item of matched.slice(0, visibleLimit)) item.hidden = false;

		const shown = Math.min(visibleLimit, matched.length);
		if (count) {
			count.textContent =
				matched.length > shown
					? `Viser ${shown} af ${matched.length} opskrifter`
					: `Viser ${shown} opskrifter`;
		}

		if (empty) empty.toggleAttribute('hidden', matched.length !== 0);

		if (loadMore instanceof HTMLButtonElement) {
			const hasMore = matched.length > shown;
			loadMore.hidden = !hasMore;
			loadMore.textContent = hasMore ? `Vis flere (${matched.length - shown} tilbage)` : 'Vis flere';
		}

		updateUrl();
	}

	hydrateFromUrl();
	applyFilters(true);

	category?.addEventListener('change', () => applyFilters(true));
	season?.addEventListener('change', () => applyFilters(true));
	maxTime?.addEventListener('change', () => applyFilters(true));
	reset?.addEventListener('click', () => {
		if (category instanceof HTMLSelectElement) category.value = '';
		if (season instanceof HTMLSelectElement) season.value = '';
		if (maxTime instanceof HTMLSelectElement) maxTime.value = '';
		applyFilters(true);
	});

	loadMore?.addEventListener('click', () => {
		visibleLimit += STEP_VISIBLE;
		applyFilters(false);
	});
</script>

<style>
	.recipe-filters {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.5rem;
		margin: 0 0 0.75rem;
		align-items: end;
	}

	.recipe-filters label {
		display: grid;
		gap: 0.2rem;
		font-size: 0.82rem;
		color: var(--muted-foreground);
	}

	.recipe-filters .filter-select {
		width: 100%;
		padding: 0.35rem 0.5rem;
		border: 1px solid var(--border-color);
		border-radius: 0.5rem;
		background: var(--surface);
		color: var(--foreground);
		font-size: 0.84rem;
		line-height: 1.2;
		min-height: 1.95rem;
	}

	.filter-count {
		margin: 0 0 1rem;
		color: var(--muted-foreground);
		font-size: 0.95rem;
	}

	.filter-links {
		margin: 0 0 0.75rem;
	}

	#filter-reset.filter-reset-btn {
		min-height: 1.95rem;
		padding: 0.3rem 0.6rem;
		font-size: 0.84rem;
	}

	.filter-empty {
		margin: 0 0 1rem;
		color: var(--muted-foreground);
	}

	.load-more-wrap {
		display: flex;
		justify-content: center;
		margin-top: 1rem;
	}

	@media (max-width: 900px) {
		.recipe-filters {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 600px) {
		.recipe-filters {
			grid-template-columns: 1fr;
		}
	}
</style>
