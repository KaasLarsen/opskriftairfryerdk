---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { ORGANIZATION_JSON, SITE_NAME, SITE_URL } from '../../consts';
import { parseWattsFromTitle } from '../../lib/parseWattsFromTitle';
import { findShopProductByProductUrl } from '../../lib/shopProductsFromJson';
import { toAbsoluteUrl } from '../../utils/seo';
import type { ShopProductJson } from '../../data/shop-curation';

export async function getStaticPaths() {
	const reviews = await getCollection('airfryerReviews');
	return reviews.map((review) => {
		const product = findShopProductByProductUrl(review.data.shopProductUrl);
		if (!product) {
			throw new Error(
				`Anmeldelse «${review.id}»: ingen vare i shop-products.json matcher shopProductUrl. Kør npm run build (med sync) eller opdatér URL i frontmatter.`,
			);
		}
		return { params: { slug: review.id }, props: { review, product } };
	});
}

interface Props {
	review: CollectionEntry<'airfryerReviews'>;
	product: ShopProductJson;
}

const { review, product } = Astro.props;
const { Content } = await render(review);
const d = review.data;

const allReviews = await getCollection('airfryerReviews');
const otherReviews = allReviews
	.filter((r) => r.id !== review.id)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6)
	.map((r) => {
		const p = findShopProductByProductUrl(r.data.shopProductUrl);
		return {
			id: r.id,
			title: r.data.title,
			thumb: r.data.heroImage ?? p?.imageUrl ?? null,
		};
	});

const site = Astro.site;
if (!site) {
	throw new Error('Konfigurer site i astro.config.mjs');
}

const canonicalPath = `/anmeldelser/${review.id}`;
const pageUrl = new URL(canonicalPath, site).toString();

const heroSrc = d.heroImage ?? product.imageUrl ?? null;
const heroAlt = d.heroAlt ?? product.title;
const ogImageAbs = heroSrc
	? toAbsoluteUrl(site, heroSrc)
	: new URL('/og-default.svg', site).toString();

const published = d.pubDate.toISOString();
const modified = (d.updatedDate ?? d.pubDate).toISOString();

function formatDk(n: number | null): string {
	if (n == null) return '';
	return new Intl.NumberFormat('da-DK', {
		style: 'currency',
		currency: 'DKK',
		maximumFractionDigits: 0,
	}).format(n);
}

const priceStr = formatDk(product.price);
const listStr = formatDk(product.listPrice);
const onSale =
	product.price != null && product.listPrice != null && product.listPrice > product.price;
const ctaLabel = (product.retailer ?? '').trim()
	? `Se pris hos ${(product.retailer ?? '').trim()}`
	: 'Se hos forhandleren';

const brandDisplay = (d.brandLabel ?? product.brand ?? '').trim();

const quickFacts: { label: string; value: string }[] = [];
if (brandDisplay) {
	quickFacts.push({ label: 'Mærke', value: brandDisplay });
}
const watts = parseWattsFromTitle(product.title);
if (watts != null) {
	quickFacts.push({
		label: 'Effekt',
		value: `${new Intl.NumberFormat('da-DK').format(watts)} W`,
	});
}
if (product.capacityLiters != null) {
	quickFacts.push({
		label: 'Kapacitet',
		value: `ca. ${String(product.capacityLiters)} L (kurv)`,
	});
}
if ((product.color ?? '').trim()) {
	quickFacts.push({ label: 'Farve', value: (product.color ?? '').trim() });
}

const productSchemaImage = heroSrc
	? toAbsoluteUrl(site, heroSrc)
	: product.imageUrl
		? toAbsoluteUrl(site, product.imageUrl)
		: undefined;

const breadcrumbJson = {
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Forside', item: `${SITE_URL}/` },
		{ '@type': 'ListItem', position: 2, name: 'Anmeldelser', item: `${SITE_URL}/anmeldelser` },
		{ '@type': 'ListItem', position: 3, name: d.title, item: pageUrl },
	],
};

const webPageJson = {
	'@type': 'WebPage',
	'@id': `${pageUrl}#webpage`,
	url: pageUrl,
	name: d.title,
	description: d.description,
	inLanguage: 'da-DK',
	isPartOf: { '@id': `${SITE_URL}/#website` },
	datePublished: published,
	dateModified: modified,
};

const articleJson = {
	'@type': 'Article',
	headline: d.title,
	description: d.description,
	image: ogImageAbs,
	inLanguage: 'da-DK',
	datePublished: published,
	dateModified: modified,
	author: { '@id': `${SITE_URL}/#organization` },
	publisher: { '@id': `${SITE_URL}/#organization` },
	mainEntityOfPage: { '@id': `${pageUrl}#webpage` },
};

const productJson: Record<string, unknown> = {
	'@type': 'Product',
	name: product.title,
	image: productSchemaImage,
	brand: product.brand ? { '@type': 'Brand', name: product.brand } : undefined,
};

const reviewJson: Record<string, unknown> = {
	'@type': 'Review',
	'@id': `${pageUrl}#review`,
	itemReviewed: productJson,
	author: { '@id': `${SITE_URL}/#organization` },
	reviewBody: d.verdict ?? d.description,
	datePublished: published,
	inLanguage: 'da-DK',
};

if (d.rating != null) {
	reviewJson.reviewRating = {
		'@type': 'Rating',
		ratingValue: d.rating,
		bestRating: 5,
		worstRating: 1,
	};
}

const jsonLd = [
	ORGANIZATION_JSON as Record<string, unknown>,
	webPageJson,
	articleJson,
	breadcrumbJson,
	reviewJson,
];
---

<BaseLayout
	title={`${d.title} | ${SITE_NAME}`}
	description={d.description}
	{canonicalPath}
	ogImage={ogImageAbs}
	ogImageAlt={heroAlt}
	ogType="article"
	articlePublishedTime={published}
	articleModifiedTime={modified}
	{jsonLd}
>
	<article class="section recipe-article">
		<div class="container recipe-article-inner">
			<nav class="recipe-breadcrumbs" aria-label="Brødkrummer">
				<a href="/">Forside</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<a href="/anmeldelser">Anmeldelser</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<span class="recipe-breadcrumbs-current">{d.title}</span>
			</nav>

			<div class="recipe-hero review-hero">
				<div
					class:list={['recipe-hero-img', !heroSrc && 'recipe-hero-img--placeholder']}
				>
					{
						heroSrc ? (
							<img
								src={heroSrc}
								alt={heroAlt}
								width="859"
								height="1024"
								fetchpriority="high"
								decoding="async"
							/>
						) : (
							<div
								class="recipe-placeholder-inner"
								role="img"
								aria-label="Produktbillede ikke tilgængeligt"
							>
								<span class="recipe-placeholder-label">Billede på vej</span>
							</div>
						)
					}
				</div>
				<div class="recipe-hero-copy">
					<p class="section-kicker review-kicker">Airfryer-anmeldelse</p>
					<h1 class="recipe-title">{d.title}</h1>
					<p class="review-product-line">
						{brandDisplay ? <strong>{brandDisplay}</strong> : null}
						{product.capacityLiters != null && (
							<>
								{' '}
								· ca. {String(product.capacityLiters)} L kurv
							</>
						)}
					</p>
					<div class="review-cta-panel">
						{
							priceStr && (
								<p class="review-price">
									<span class="review-price-label">Vejl. pris hos forhandler</span>
									<span class="review-price-value">{priceStr}</span>
									{onSale && listStr && (
										<span class="review-price-was">før {listStr}</span>
									)}
								</p>
							)
						}
						<a
							class="btn btn-primary review-cta"
							href={product.productUrl}
							target="_blank"
							rel="sponsored noopener noreferrer"
						>
							{ctaLabel}
						</a>
						<p class="review-disclaimer">
							Linket er et reklamelink (partner). Pris, lager og levering kan ændre sig – tjek altid
							hos forhandleren.
						</p>
					</div>
				</div>
			</div>

			{
				quickFacts.length > 0 && (
					<section class="review-quick-facts" aria-labelledby="review-quick-facts-h">
						<h2 id="review-quick-facts-h" class="review-quick-facts-heading">
							På et øjeblik
						</h2>
						<dl class="review-quick-facts-dl">
							{
								quickFacts.flatMap(({ label, value }) => [
									<dt>{label}</dt>,
									<dd>{value}</dd>,
								])
							}
						</dl>
					</section>
				)
			}

			<div class="review-pros-cons">
				<div class="review-pros">
					<h2>Fordele</h2>
					<ul>
						{d.pros.map((t) => (
							<li>{t}</li>
						))}
					</ul>
				</div>
				<div class="review-cons">
					<h2>Ulemper</h2>
					<ul>
						{d.cons.map((t) => (
							<li>{t}</li>
						))}
					</ul>
				</div>
			</div>

			{
				d.rating != null && (
					<p class="review-rating-summary" aria-label="Vurdering">
						<strong>Samlet vurdering:</strong>{' '}
						<span class="review-stars">
							{Array.from({ length: d.rating }, () => '★').join('')}
							{Array.from({ length: 5 - d.rating }, () => '☆').join('')}
						</span>
						<span class="review-rating-num"> ({d.rating}/5)</span>
					</p>
				)
			}

			<div class="prose review-body">
				<Content />
			</div>

			{
				d.verdict && (
					<div class="review-verdict">
						<h2>Konklusion</h2>
						<p>{d.verdict}</p>
					</div>
				)
			}

			{
				otherReviews.length > 0 && (
					<aside class="review-see-also" aria-labelledby="review-see-also-heading">
						<h2 id="review-see-also-heading" class="review-see-also-heading">
							Se også
						</h2>
						<p class="review-see-also-lead">Andre airfryer-anmeldelser på sitet:</p>
						<ul class="review-see-also-list" role="list">
							{otherReviews.map((o) => (
								<li>
									<a class="review-see-also-card" href={`/anmeldelser/${o.id}`}>
										{o.thumb ? (
											<img
												class="review-see-also-thumb"
												src={o.thumb}
												alt=""
												width="96"
												height="96"
												loading="lazy"
												decoding="async"
											/>
										) : (
											<span class="review-see-also-fallback" aria-hidden="true" />
										)}
										<span class="review-see-also-title">{o.title}</span>
									</a>
								</li>
							))}
						</ul>
					</aside>
				)
			}

			<p class="review-back">
				<a href="/anmeldelser">← Tilbage til alle anmeldelser</a>
			</p>
		</div>
	</article>
</BaseLayout>

<style>
	.review-quick-facts {
		margin: var(--space-10) 0 var(--space-10);
		padding: var(--space-6) var(--space-7);
		border-radius: var(--radius-xl);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
	}
	.review-quick-facts-heading {
		font-family: var(--font-display);
		font-size: 1.15rem;
		margin: 0 0 var(--space-4);
	}
	.review-quick-facts-dl {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-2) var(--space-6);
		margin: 0;
		align-items: baseline;
	}
	.review-quick-facts-dl dt {
		font-size: 0.875rem;
		font-weight: 650;
		color: var(--color-muted);
		margin: 0;
	}
	.review-quick-facts-dl dd {
		margin: 0;
		font-size: 1rem;
	}
	/* Anmeldelses-hero: produktfoto er ofte højformat; undgå 4:3-beskæring fra opskrift-layout */
	.review-hero .recipe-hero-img img {
		aspect-ratio: auto;
		height: auto;
		max-height: min(62vh, 36rem);
		object-fit: contain;
		background: var(--color-surface);
	}
	.review-kicker {
		margin-bottom: var(--space-2);
	}
	.review-product-line {
		color: var(--color-muted);
		margin: 0 0 var(--space-6);
		font-size: 1.05rem;
	}
	.review-cta-panel {
		padding: var(--space-6);
		border-radius: var(--radius-xl);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		margin-bottom: var(--space-4);
	}
	.review-price {
		margin: 0 0 var(--space-4);
	}
	.review-price-label {
		display: block;
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		margin-bottom: var(--space-1);
	}
	.review-price-value {
		font-family: var(--font-display);
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--color-text);
	}
	.review-price-was {
		display: block;
		font-size: 0.9375rem;
		color: var(--color-muted);
		text-decoration: line-through;
		margin-top: var(--space-1);
	}
	.review-cta {
		display: inline-flex;
		margin-bottom: var(--space-3);
	}
	.review-disclaimer {
		margin: 0;
		font-size: 0.875rem;
		color: var(--color-muted);
		line-height: 1.55;
		max-width: 36rem;
	}
	.review-pros-cons {
		display: grid;
		gap: var(--space-8);
		margin: var(--space-12) 0 var(--space-10);
	}
	@media (min-width: 700px) {
		.review-pros-cons {
			grid-template-columns: 1fr 1fr;
			align-items: start;
		}
	}
	.review-pros h2,
	.review-cons h2 {
		font-family: var(--font-display);
		font-size: 1.15rem;
		margin: 0 0 var(--space-4);
	}
	.review-pros h2 {
		color: var(--color-accent-dark);
	}
	.review-cons h2 {
		color: var(--color-text);
	}
	.review-pros ul,
	.review-cons ul {
		margin: 0;
		padding-left: 1.2rem;
		line-height: 1.65;
		color: var(--color-text);
	}
	.review-pros li,
	.review-cons li {
		margin-bottom: var(--space-2);
	}
	.review-rating-summary {
		margin: 0 0 var(--space-8);
		font-size: 1.05rem;
	}
	.review-stars {
		color: rgb(180 83 9);
		letter-spacing: 0.06em;
	}
	.review-rating-num {
		color: var(--color-muted);
	}
	.review-verdict {
		margin-top: var(--space-10);
		margin-bottom: var(--space-10);
		padding: var(--space-6) var(--space-7);
		border-radius: var(--radius-xl);
		border: 1px solid rgb(180 83 9 / 22%);
		background: rgb(180 83 9 / 6%);
	}
	.review-verdict h2 {
		margin: 0 0 var(--space-3);
		font-size: 1.2rem;
	}
	.review-verdict p {
		margin: 0;
		line-height: 1.65;
	}
	.review-body {
		margin-top: var(--space-10);
	}
	.review-see-also {
		margin-top: var(--space-12);
		padding: var(--space-7) var(--space-6);
		border-radius: var(--radius-xl);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
	}
	.review-see-also-heading {
		font-family: var(--font-display);
		font-size: 1.2rem;
		margin: 0 0 var(--space-2);
	}
	.review-see-also-lead {
		margin: 0 0 var(--space-5);
		font-size: 0.9375rem;
		color: var(--color-muted);
		line-height: 1.5;
	}
	.review-see-also-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: var(--space-3);
	}
	@media (min-width: 520px) {
		.review-see-also-list {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	.review-see-also-card {
		display: flex;
		align-items: center;
		gap: var(--space-4);
		padding: var(--space-3) var(--space-4);
		border-radius: var(--radius-lg);
		border: 1px solid rgb(0 0 0 / 8%);
		background: var(--color-bg);
		text-decoration: none;
		color: var(--color-text);
		transition: border-color 0.15s ease, box-shadow 0.15s ease;
	}
	.review-see-also-card:hover {
		border-color: rgb(180 83 9 / 35%);
		box-shadow: var(--shadow-sm);
	}
	.review-see-also-thumb {
		width: 4.5rem;
		height: 4.5rem;
		object-fit: cover;
		border-radius: var(--radius-md);
		flex-shrink: 0;
	}
	.review-see-also-fallback {
		width: 4.5rem;
		height: 4.5rem;
		flex-shrink: 0;
		border-radius: var(--radius-md);
		background: rgb(0 0 0 / 6%);
	}
	.review-see-also-title {
		font-weight: 600;
		font-size: 0.9375rem;
		line-height: 1.4;
	}
	.review-back {
		margin-top: var(--space-12);
	}
</style>
