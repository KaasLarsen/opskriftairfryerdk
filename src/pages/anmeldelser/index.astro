---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { ORGANIZATION_JSON, SITE_NAME, SITE_URL } from '../../consts';
import { parseWattsFromTitle } from '../../lib/parseWattsFromTitle';
import { findShopProductByProductUrl } from '../../lib/shopProductsFromJson';

const reviews = (await getCollection('airfryerReviews')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function capacityBucket(liters: number | null | undefined): string {
	if (liters == null || !Number.isFinite(Number(liters))) return 'unknown';
	const v = Number(liters);
	if (v < 5) return 'lt5';
	if (v <= 7) return '5-7';
	return 'gt7';
}

function brandKey(brand: string): string {
	const t = brand.trim().toLowerCase();
	if (!t) return 'ukendt';
	return t.replace(/\s+/g, '-');
}

const indexEntries = reviews.map((r) => {
	const p = findShopProductByProductUrl(r.data.shopProductUrl);
	const brand = (r.data.brandLabel ?? p?.brand ?? '').trim();
	return {
		id: r.id,
		title: r.data.title,
		description: r.data.description,
		rating: r.data.rating,
		thumb: r.data.heroImage ?? p?.imageUrl ?? null,
		brand,
		brandFilter: brandKey(brand),
		capacityLiters: p?.capacityLiters,
		capBucket: capacityBucket(p?.capacityLiters ?? null),
		watts: p ? parseWattsFromTitle(p.title) : null,
		pubDateMs: r.data.pubDate.valueOf(),
	};
});

const brandOptions = [
	...new Set(indexEntries.map((e) => e.brand).filter((b) => b.length > 0)),
].sort((a, b) => a.localeCompare(b, 'da', { sensitivity: 'base' }));

const title = `Airfryer-anmeldelser | ${SITE_NAME}`;
const description =
	'Praktiske airfryer-anmeldelser: fordele, ulemper og hvem modellen passer til – med link til forhandler og vejledende pris.';

const jsonLd = [
	ORGANIZATION_JSON as Record<string, unknown>,
	{
		'@type': 'WebPage',
		'@id': `${SITE_URL}/anmeldelser#webpage`,
		url: `${SITE_URL}/anmeldelser`,
		name: title.replace(` | ${SITE_NAME}`, ''),
		description,
		inLanguage: 'da-DK',
		isPartOf: { '@id': `${SITE_URL}/#website` },
	},
];
---

<BaseLayout title={title} {description} canonicalPath="/anmeldelser" jsonLd={jsonLd}>
	<section class="section section--tight-top">
		<div class="container">
			<nav class="recipe-breadcrumbs" aria-label="Brødkrummer">
				<a href="/">Forside</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<span class="recipe-breadcrumbs-current">Anmeldelser</span>
			</nav>

			<div class="section-head">
				<p class="section-kicker">Anmeldelser</p>
				<h1 class="recipe-title">Airfryer-anmeldelser</h1>
				<p>
					Du finder <strong>{reviews.length} anmeldelser</strong> på denne side under filtrene – vælg
					<em>Alle mærker</em>, <em>Alle størrelser</em> og <em>Alle</em> under vurdering for at se hele
					listen. Vi <strong>vurderer og beskriver</strong> modeller med klare fordele og ulemper, så du
					lettere kan vælge. Tjek altid den aktuelle vareside hos forhandleren, før du bestemmer dig. Læs
					også <a href="/guides/hvilken-airfryer">guiden til at vælge airfryer</a>.
				</p>
			</div>

			<form
				class="review-index-filters"
				id="review-index-filters"
				aria-label="Filtrer anmeldelser"
				autocomplete="off"
				onsubmit="return false;"
			>
				<p class="review-index-filters-hint">
					Ser du færre end {reviews.length} anmeldelser, eller ingen på listen? Vælg <strong>Alle</strong> i
					menuerne nedenfor og klik <strong>Nulstil filtre</strong>. Listen følger dine valg: vælger du fx
					<strong>5 stjerner</strong>, ser du kun modeller med topvurdering.
				</p>
				<div class="review-index-filters-row">
					<div class="review-index-filter">
						<label class="review-index-filter-label" for="filter-review-brand">Mærke</label>
						<select
							class="review-index-select"
							id="filter-review-brand"
							data-filter-brand
							autocomplete="off"
						>
							<option value="">Alle mærker</option>
							{
								brandOptions.map((b) => (
									<option value={brandKey(b)}>{b}</option>
								))
							}
							{
								indexEntries.some((e) => !e.brand) ? (
									<option value="ukendt">Mærke ikke oplyst</option>
								) : null
							}
						</select>
					</div>
					<div class="review-index-filter">
						<label class="review-index-filter-label" for="filter-review-cap">Kapacitet (kurv)</label>
						<select
							class="review-index-select"
							id="filter-review-cap"
							data-filter-cap
							autocomplete="off"
						>
							<option value="">Alle størrelser</option>
							<option value="lt5">Under 5 L</option>
							<option value="5-7">5–7 L</option>
							<option value="gt7">Over 7 L</option>
							<option value="unknown">Kapacitet ikke oplyst</option>
						</select>
					</div>
					<div class="review-index-filter">
						<label class="review-index-filter-label" for="filter-review-rating">Mindst vurdering</label>
						<select
							class="review-index-select"
							id="filter-review-rating"
							data-filter-rating
							autocomplete="off"
						>
							<option value="">Alle</option>
							<option value="4">4 stjerner eller mere</option>
							<option value="5">5 stjerner</option>
						</select>
					</div>
					<div class="review-index-filter">
						<label class="review-index-filter-label" for="filter-review-sort">Sortering</label>
						<select
							class="review-index-select"
							id="filter-review-sort"
							data-filter-sort
							autocomplete="off"
						>
							<option value="date-desc">Nyeste først</option>
							<option value="date-asc">Ældste først</option>
							<option value="cap-desc">Størst kapacitet</option>
							<option value="cap-asc">Mindst kapacitet</option>
						</select>
					</div>
				</div>
				<div class="review-index-filters-actions">
					<button type="button" class="review-index-reset" data-filter-reset>Nulstil filtre</button>
					<p class="review-index-filter-status" data-filter-status aria-live="polite" />
				</div>
			</form>

			<ul class="review-index-list" id="review-index-list" role="list">
				{
					indexEntries.map((e) => (
						<li
							data-review-item
							data-brand={e.brandFilter}
							data-cap-bucket={e.capBucket}
							data-rating={e.rating ?? ''}
							data-liters={e.capacityLiters != null ? String(e.capacityLiters) : ''}
							data-date={String(e.pubDateMs)}
						>
							<a class="review-index-card" href={`/anmeldelser/${e.id}`}>
								{e.thumb ? (
									<img
										class="review-index-thumb"
										src={e.thumb}
										alt=""
										width="140"
										height="140"
										loading="lazy"
										decoding="async"
									/>
								) : (
									<span class="review-index-thumb review-index-thumb--placeholder" aria-hidden="true" />
								)}
								<div class="review-index-card-main">
									<span class="review-index-kicker">Anmeldelse</span>
									{e.brand || e.capacityLiters != null || e.watts != null ? (
										<p class="review-index-meta">
											{e.brand ? <span class="review-index-chip">{e.brand}</span> : null}
											{e.capacityLiters != null ? (
												<span class="review-index-chip">ca. {String(e.capacityLiters)} L</span>
											) : null}
											{e.watts != null ? (
												<span class="review-index-chip">
													{new Intl.NumberFormat('da-DK').format(e.watts)} W
												</span>
											) : null}
										</p>
									) : null}
									<span class="review-index-title">{e.title}</span>
									<span class="review-index-desc">{e.description}</span>
								</div>
								{e.rating != null ? (
									<span class="review-index-rating" aria-label={`Vurdering ${e.rating} af 5`}>
										{e.rating}/5
									</span>
								) : null}
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</section>
</BaseLayout>

<script is:inline>
	(function () {
		const root = document.getElementById('review-index-filters');
		const list = document.getElementById('review-index-list');
		if (!root || !list) return;

		const brandSel = root.querySelector('[data-filter-brand]');
		const capSel = root.querySelector('[data-filter-cap]');
		const ratingSel = root.querySelector('[data-filter-rating]');
		const sortSel = root.querySelector('[data-filter-sort]');
		const resetBtn = root.querySelector('[data-filter-reset]');
		const statusEl = root.querySelector('[data-filter-status]');
		if (
			!(brandSel instanceof HTMLSelectElement) ||
			!(capSel instanceof HTMLSelectElement) ||
			!(ratingSel instanceof HTMLSelectElement) ||
			!(sortSel instanceof HTMLSelectElement) ||
			!(resetBtn instanceof HTMLButtonElement) ||
			!(statusEl instanceof HTMLElement)
		) {
			return;
		}

		function getItems() {
			return Array.prototype.slice.call(list.querySelectorAll('[data-review-item]'));
		}

		function sortItems(mode) {
			const items = getItems();
			function score(li) {
				const raw = li.dataset.liters || '';
				const n = parseFloat(String(raw).replace(',', '.'));
				return Number.isFinite(n) ? n : -1;
			}
			function date(li) {
				return parseInt(li.dataset.date || '0', 10) || 0;
			}
			items.sort(function (a, b) {
				if (mode === 'date-asc') return date(a) - date(b);
				if (mode === 'date-desc') return date(b) - date(a);
				if (mode === 'cap-asc') {
					var va = score(a);
					var vb = score(b);
					if (va < 0 && vb < 0) return date(b) - date(a);
					if (va < 0) return 1;
					if (vb < 0) return -1;
					return va - vb;
				}
				if (mode === 'cap-desc') {
					var v1 = score(a);
					var v2 = score(b);
					if (v1 < 0 && v2 < 0) return date(b) - date(a);
					if (v1 < 0) return 1;
					if (v2 < 0) return -1;
					return v2 - v1;
				}
				return date(b) - date(a);
			});
			var frag = document.createDocumentFragment();
			for (var i = 0; i < items.length; i++) frag.appendChild(items[i]);
			list.appendChild(frag);
		}

		function apply() {
			sortItems(sortSel.value);
			var items = getItems();
			var wantBrand = brandSel.value;
			var wantCap = capSel.value;
			var wantRating = ratingSel.value;
			var shown = 0;
			for (var j = 0; j < items.length; j++) {
				var li = items[j];
				var ok = true;
				if (wantBrand && (li.dataset.brand || '') !== wantBrand) ok = false;
				if (wantCap && (li.dataset.capBucket || '') !== wantCap) ok = false;
				if (wantRating) {
					var r = parseFloat(li.dataset.rating || '');
					var min = parseFloat(wantRating);
					if (!Number.isFinite(r) || r < min) ok = false;
				}
				li.hidden = !ok;
				if (ok) shown++;
			}
			if (shown === items.length) {
				statusEl.textContent = '';
			} else {
				statusEl.textContent =
					shown === 0
						? 'Ingen anmeldelser matcher – prøv at lempe filtrene.'
						: shown + ' af ' + items.length + ' anmeldelser matcher.';
			}
		}

		brandSel.addEventListener('change', apply);
		capSel.addEventListener('change', apply);
		ratingSel.addEventListener('change', apply);
		sortSel.addEventListener('change', apply);
		resetBtn.addEventListener('click', function () {
			brandSel.value = '';
			capSel.value = '';
			ratingSel.value = '';
			sortSel.value = 'date-desc';
			apply();
		});

		// Ryd evt. gendannede formulardata (ellers kan «kun 5 stjerner» el.l. skjule næsten alt)
		brandSel.value = '';
		capSel.value = '';
		ratingSel.value = '';
		sortSel.value = 'date-desc';
		apply();
	})();
</script>

<style>
	.review-index-filters {
		max-width: 52rem;
		margin: var(--space-8) 0 var(--space-10);
		padding: var(--space-6) var(--space-6);
		border-radius: var(--radius-xl);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
	}
	.review-index-filters-hint {
		margin: 0 0 var(--space-5);
		font-size: 0.9rem;
		line-height: 1.55;
		color: var(--color-muted);
	}
	.review-index-filters-row {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-5) var(--space-6);
		align-items: flex-end;
	}
	.review-index-filter {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		min-width: min(100%, 11rem);
		flex: 1 1 10rem;
	}
	.review-index-filter-label {
		font-size: 0.8125rem;
		font-weight: 650;
		color: var(--color-muted);
	}
	.review-index-select {
		font: inherit;
		font-size: 0.9375rem;
		padding: var(--space-3) var(--space-4);
		border-radius: var(--radius-lg);
		border: 1px solid var(--color-border);
		background: var(--color-bg);
		color: var(--color-text);
		cursor: pointer;
		width: 100%;
	}
	.review-index-select:focus {
		outline: 2px solid rgb(180 83 9 / 45%);
		outline-offset: 2px;
	}
	.review-index-filters-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-4);
		margin-top: var(--space-5);
		padding-top: var(--space-4);
		border-top: 1px solid rgb(0 0 0 / 6%);
	}
	.review-index-reset {
		font: inherit;
		font-size: 0.875rem;
		font-weight: 600;
		padding: var(--space-2) var(--space-4);
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		background: transparent;
		color: var(--color-text);
		cursor: pointer;
	}
	.review-index-reset:hover {
		border-color: rgb(180 83 9 / 35%);
		color: rgb(120 53 15);
	}
	.review-index-filter-status {
		margin: 0;
		font-size: 0.875rem;
		color: var(--color-muted);
		flex: 1;
		min-width: 12rem;
	}
	.review-index-list {
		list-style: none;
		margin: 0;
		padding: 0;
		max-width: 52rem;
	}
	.review-index-list li + li {
		margin-top: var(--space-4);
	}
	.review-index-card {
		display: flex;
		align-items: flex-start;
		gap: var(--space-5);
		padding: var(--space-5) var(--space-6);
		border-radius: var(--radius-xl);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		box-shadow: var(--shadow-xs);
		text-decoration: none;
		color: inherit;
		transition:
			border-color 0.15s ease,
			box-shadow 0.15s ease;
	}
	.review-index-card:hover {
		border-color: rgb(180 83 9 / 28%);
		box-shadow: var(--shadow-sm);
	}
	.review-index-thumb {
		width: 6.25rem;
		height: 6.25rem;
		object-fit: cover;
		border-radius: var(--radius-lg);
		flex-shrink: 0;
		border: 1px solid rgb(0 0 0 / 8%);
	}
	.review-index-thumb--placeholder {
		display: block;
		background: rgb(0 0 0 / 6%);
	}
	.review-index-card-main {
		flex: 1;
		min-width: 0;
	}
	.review-index-kicker {
		display: block;
		font-size: 0.8125rem;
		font-weight: 650;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--color-accent-dark);
		margin-bottom: var(--space-2);
	}
	.review-index-meta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-2);
		margin: 0 0 var(--space-3);
	}
	.review-index-chip {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.2rem 0.55rem;
		border-radius: var(--radius-md);
		background: rgb(0 0 0 / 6%);
		color: var(--color-muted);
	}
	.review-index-title {
		display: block;
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--color-text);
		margin-bottom: var(--space-3);
		line-height: 1.25;
	}
	.review-index-desc {
		display: block;
		font-size: 0.98rem;
		line-height: 1.6;
		color: var(--color-muted);
	}
	.review-index-rating {
		flex-shrink: 0;
		font-weight: 700;
		font-size: 0.9375rem;
		color: rgb(180 83 9);
		line-height: 1.2;
		padding-top: 0.125rem;
	}
	@media (max-width: 520px) {
		.review-index-card {
			flex-wrap: wrap;
		}
		.review-index-rating {
			flex-basis: 100%;
		}
	}
</style>
