---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuidePriceRunnerSpotlight from '../../components/GuidePriceRunnerSpotlight.astro';
import { ORGANIZATION_JSON, SITE_NAME, SITE_URL } from '../../consts';

const canonicalPath = '/guides/hvilken-airfryer';
const pageUrl = new URL(canonicalPath, SITE_URL).toString();
const title = `Hvilken airfryer skal du vælge? Størrelse, husholdning og funktioner | ${SITE_NAME}`;
const description =
	'Vælg airfryer efter kurvstørrelse, antal personer og madvaner: én kurv vs. dobbelt zone, plads på bordet og rengøring. Plus hvordan du bruger shop-filtrene.';

const published = '2026-04-05T08:00:00.000Z';
const modified = '2026-05-24T16:00:00.000Z';

const heroImagePath = '/images/guides/hvilken-airfryer.png';
const heroImageWidth = 1024;
const heroImageHeight = 818;
const heroAlt =
	'Flere airfryermodeller på række med mad i kurvene og tallerkener med pomfritter, nuggets, laks og grønt – guide til valg af airfryer';
const ogImage = new URL(heroImagePath, SITE_URL).toString();

const faqItems = [
	{
		q: 'Hvor mange liter kurv skal jeg vælge?',
		a: 'Som tommelfingerregel: 3–5 liter til 1–2 personer til hverdagsmåltider, 5–7+ liter til familie eller når du ofte vil lave både protein og tilbehør samme aften. Tænk i gram mad ad gangen – ikke kun liter.',
	},
	{
		q: 'Er dobbelt zone eller to kurve det værd?',
		a: 'Hvis du ofte vil lave to ting med forskellig tid eller temperatur uden at skifte imellem, giver to zoner mening. Til én ret ad gangen eller små mængder kan én god kurv være alt, du behøver.',
	},
	{
		q: 'Kan jeg stege en hel kylling i enhver airfryer?',
		a: 'Det afhænger af model og kurvform. Tjek altid, at der er højde og plads omkring kyllingen, og følg en opskrift til din størrelse maskine – se fx vores hel kylling-opskrift.',
	},
	{
		q: 'Betyder watt noget for resultatet?',
		a: 'Højere effekt kan give hurtigere opvarmning, men jævn cirkulation og at du bruger ét lag og rette tider betyder ofte mere for resultatet end watt alene.',
	},
	{
		q: 'Hvor finder jeg luftfriture-modeller at sammenligne?',
		a: 'På vores shop-side samler vi udvalgte airfryere og tilbehør fra samarbejdspartnere; du filtrerer fx på kurvstørrelse og pris og går videre til forhandlerens side for aktuel pris.',
	},
	{
		q: 'Er &quot;mini-ovn&quot;-airfryer og klassisk kurv det samme?',
		a: 'Udformningen varierer: nogle ligner små ovne med trådkurve eller plader, andre har dybe skuffer. Det afgørende er stadig luft omkring maden og indvendige mål ift. det du laver oftest – ikke kun produktnavnet.',
	},
];

const breadcrumbJson = {
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Forside', item: `${SITE_URL}/` },
		{ '@type': 'ListItem', position: 2, name: 'Guides', item: `${SITE_URL}/guides` },
		{ '@type': 'ListItem', position: 3, name: 'Hvilken airfryer', item: pageUrl },
	],
};

const webPageJson = {
	'@type': 'WebPage',
	'@id': `${pageUrl}#webpage`,
	url: pageUrl,
	name: title.replace(` | ${SITE_NAME}`, ''),
	description,
	inLanguage: 'da-DK',
	isPartOf: { '@id': `${SITE_URL}/#website` },
	datePublished: published,
	dateModified: modified,
};

const articleJson = {
	'@type': 'Article',
	headline: 'Hvilken airfryer skal du vælge? Størrelse, husholdning og funktioner',
	description,
	image: ogImage,
	inLanguage: 'da-DK',
	datePublished: published,
	dateModified: modified,
	author: { '@id': `${SITE_URL}/#organization` },
	publisher: { '@id': `${SITE_URL}/#organization` },
	mainEntityOfPage: { '@id': `${pageUrl}#webpage` },
};

const faqJson = {
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.q,
		acceptedAnswer: { '@type': 'Answer', text: item.a },
	})),
};

const jsonLd = [
	ORGANIZATION_JSON as Record<string, unknown>,
	webPageJson,
	articleJson,
	breadcrumbJson,
	faqJson,
];
---

<BaseLayout
	title={title}
	{description}
	{canonicalPath}
	ogImage={ogImage}
	ogImageAlt={heroAlt}
	ogImageWidth={heroImageWidth}
	ogImageHeight={heroImageHeight}
	ogType="article"
	articlePublishedTime={published}
	articleModifiedTime={modified}
	{jsonLd}
>
	<section class="section section--tight-top">
		<div class="container">
			<nav class="recipe-breadcrumbs" aria-label="Brødkrummer">
				<a href="/">Forside</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<a href="/guides">Guides</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<span class="recipe-breadcrumbs-current">Hvilken airfryer</span>
			</nav>

			<div class="guide-hero">
				<img
					src={heroImagePath}
					alt={heroAlt}
					width={heroImageWidth}
					height={heroImageHeight}
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
			</div>

			<article class="prose guide-prose">
				<p class="section-kicker guide-article-kicker">Køb og valg</p>
				<h1>Hvilken airfryer skal du vælge? Størrelse, husholdning og funktioner</h1>
				<p class="guide-lead">
					Den &quot;bedste&quot; airfryer er den, der matcher <strong>din bordplads</strong>, hvor mange
					I er ved bordet, og om du primært vil have <strong>hurtige små retter</strong> eller ofte lave
					større mængder. Her er et roligt beslutningsgrundlag – uden mærkekrig.
				</p>

				<h2>Start med tre spørgsmål</h2>
				<ol>
					<li>
						<strong>Hvor mange spiser med?</strong> En person, par eller familie afgør, om du tolererer
						to omgange i kurven – eller helst vil have plads til mere på én gang.
					</li>
					<li>
						<strong>Hvad laver du typisk?</strong> Pommes, grønt og snacks kræver ofte bred, åben
						kurv. Store steger eller hel fugl kræver højde og diameter.
					</li>
					<li>
						<strong>Hvor meget bordplads har du?</strong> En maskine, der står fremme, bliver brugt.
						Tjek dybde og højde – især hvis skuffer skal kunne trækkes ud under hylder.
					</li>
				</ol>

				<h2>Kurvstørrelse (liter): hvad betyder det i praksis?</h2>
				<p>
					Liter er et pejlemærke for <strong>rum i kurven</strong>, ikke et løfte om mængde mad. Små
					maskiner er fine til én portion og snacks; større kurve gør det lettere at holde{' '}
					<strong>ét lag</strong> med luft imellem – se også{' '}
					<a href="/guides/airfryer-for-begyndere">airfryer for begyndere</a>.
				</p>
				<ul>
					<li>
						<strong>Kompakt (ca. 3–5 L):</strong> passer til 1–2 personer, hurtige aftenmåltider og
						opvarmning.
					</li>
					<li>
						<strong>Mellem / familie (ca. 5–7+ L):</strong> ofte bedre til børnefamilie, batch-pommes og
						når ovnen er optaget.
					</li>
				</ul>
				<p>
					På{' '}
					<a href="/shop">shop-siden</a> kan du afgrænse på <strong>kurv min/max (liter)</strong> og
					pris, så du kan sammenligne modeller, der passer til dit køkken og budget – pris og
					lager afgøres altid hos forhandleren.
				</p>

				<h2>Én kurv eller to zoner (dual)?</h2>
				<p>
					<strong>To zoner</strong> giver mening, hvis du fx vil have kylling og pommes færdige uden at
					skifte temperatur hele tiden, eller hvis I ofte laver forskellige ting med forskellig tid.{' '}
					<strong>Én kurv</strong> er enklere, billigere per funktion og nok til mange husholdninger.
				</p>

				<h2>Funktioner du kan vægte (uden at hype alt)</h2>
				<ul>
					<li>
						<strong>Forprogrammer:</strong> praktiske, men dine{' '}
						<a href="/opskrifter">opskrifter</a> med konkret tid og temperatur er ofte mere præcise.
					</li>
					<li>
						<strong>Rengøring:</strong> aftagelig kurv og skuffe der kan i opvaskemaskine (hvis
						producenten tillader det) gør det lettere at beholde maskinen.
					</li>
					<li>
						<strong>Støj og varme:</strong> læs tests og brugeranmeldelser – især hvis maskinen står i
						lille køkken.
					</li>
				</ul>

				<h2>Formfaktor: kurv, skuffe eller mini-ovn</h2>
				<p>
					Mærker beskriver maskiner forskelligt, men i praksis møder du ofte{' '}
					<strong>dyb skuffe/kurv</strong> (klassisk &quot;bucket&quot;), <strong>dobbelt skuffe</strong> med to
					zoner, eller modeller der ligner en <strong>komprimeret ovn</strong> med rist. Spørg ikke
					&quot;hvilket er bedst&quot; – spørg hvad der passer til din bordplads og til de retter, du laver
					oftest.
				</p>
				<ul>
					<li>
						Elsker du <strong>stege, fileter og pommes i én åben kurv</strong>, er bred skuffe ofte
						nemmest at håndtere.
					</li>
					<li>
						Laver du ofte <a href="/opskrifter/airfryer-hel-kylling">hel kylling</a> eller{' '}
						<a href="/opskrifter/airfryer-flaeskesteg">store steger</a>, er <strong>højde og diameter</strong>{' '}
						vigtigere end liter-tallet på æsken – tjek indvendige mål hos forhandleren.
					</li>
					<li>
						Skal maskinen stå under overskab, så <strong>højde ved åben skuffe</strong> og luftafstand
						tælles med i målene på køkkenbordet.
					</li>
				</ul>

				<h2>Watt, støj og &quot;sluger den strøm?&quot;</h2>
				<p>
					Højere effekt kan give hurtigere opvarmning, men <strong>jævn fordeling af luft</strong> og dine
					egne vaner (ét lag, ryst undervejs) har ofte større effekt på resultatet end watt-tallet alene.
					Airfryere kører typisk i kortere burst end ovn; den samlede el-regning afhænger derfor også af,
					hvor ofte du bruger maskinen og hvor længe hvert program kører. Støj er reel fodtrafik i små
					lejligheder – læs anmeldelser eller se videoer, før du vælger model til åbent køkken-stue.
				</p>

				<h2>To mål der afgør tilbehør</h2>
				<p>
					Før du køber liner, silikoneform eller ekstra rist:{' '}
					<strong>mål indvendigt i kurven</strong> og notér om indsatser er ovale, runde eller firkantede.
					&quot;Universalsæt&quot; passer sjældent alt – se vores rolige prioritering i{' '}
					<a href="/guides/tilbehoer-til-airfryer">tilbehørsguiden</a>.
				</p>

				<h2>Når du har købt: kom godt i gang</h2>
				<p>
					Start med simple retter –{' '}
					<a href="/opskrifter/airfryer-pomfritter">pomfritter</a>,{' '}
					<a href="/opskrifter/airfryer-broccoli">broccoli</a> og{' '}
					<a href="/opskrifter/airfryer-kyllingelaar">kyllingelår</a> – så lærer du kurven og din models
					temperatur. Frossen mad har sine egne vaner:{' '}
					<a href="/guides/frossen-mad-airfryer">frossen mad i airfryer</a>.
				</p>
				<p class="guide-back">
					<a href="/guides">← Tilbage til alle guides</a>
				</p>

				<GuidePriceRunnerSpotlight guideId="hvilken-airfryer" />

				<h2>Ofte stillede spørgsmål</h2>
				<div class="guide-faq">
					{
						faqItems.map((item) => (
							<details>
								<summary>{item.q}</summary>
								<p>{item.a}</p>
							</details>
						))
					}
				</div>
			</article>
		</div>
	</section>
</BaseLayout>

<style>
	.guide-hero {
		max-width: 48rem;
		margin-bottom: var(--space-8);
		border-radius: var(--radius-xl);
		overflow: hidden;
		border: 1px solid rgb(0 0 0 / 6%);
		box-shadow: var(--shadow-md);
	}
	.guide-hero img {
		display: block;
		width: 100%;
		height: auto;
		vertical-align: middle;
	}
	.guide-prose {
		max-width: 48rem;
	}
	.guide-article-kicker {
		margin-bottom: var(--space-2);
	}
	.guide-lead {
		font-size: 1.08rem;
		line-height: 1.65;
	}
	.guide-back {
		margin-top: var(--space-8);
	}
	.guide-faq {
		margin-top: var(--space-6);
	}
	.guide-faq details {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--space-4) var(--space-5);
		margin-bottom: var(--space-3);
		background: var(--color-surface);
	}
	.guide-faq summary {
		font-weight: 650;
		cursor: pointer;
		color: var(--color-text);
	}
	.guide-faq details p {
		margin: var(--space-4) 0 0;
		color: var(--color-muted);
		line-height: 1.65;
	}
</style>
