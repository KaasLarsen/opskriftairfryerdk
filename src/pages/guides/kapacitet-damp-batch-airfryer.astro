---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuidePriceRunnerSpotlight from '../../components/GuidePriceRunnerSpotlight.astro';
import { ORGANIZATION_JSON, SITE_NAME, SITE_URL } from '../../consts';

const canonicalPath = '/guides/kapacitet-damp-batch-airfryer';
const pageUrl = new URL(canonicalPath, SITE_URL).toString();
const title = `Kapacitet og damp i airfryer: ét lag, batch og sprødhed | ${SITE_NAME}`;
const description =
	'Undgå blød mad i airfryer: hvorfor overfyldt kurv giver damp, hvordan du fordeler i batch, og simple vaner der genskaber sprødhed.';

const published = '2026-04-09T12:00:00.000Z';
const modified = '2026-04-09T12:00:00.000Z';

const heroImagePath = '/images/guides/kapacitet-damp-batch-airfryer.png';
const heroImageWidth = 1376;
const heroImageHeight = 768;
const heroAlt =
	'Airfryer-kurv set fra oven: overfyldt lag kontra ét enkelt lag for bedre luftcirkulation';
const ogImage = new URL(heroImagePath, SITE_URL).toString();

const faqItems = [
	{
		q: 'Hvorfor bliver pommes bløde når jeg fylder kurven?',
		a: 'For tæt pakning giver damp mellem stykkerne fremfor tør varmluft. Færre ad gangen — eller ryst og del i to omgange — giver mere sprødt resultat.',
	},
	{
		q: 'Må jeg stable kylling i to lag med rist?',
		a: 'En rist kan hjælpe, men luft skal stadig kunne passere mellem lagene. Hvis damp ikke kan slippe væk, bliver ydersiden kedelig — overvej batch.',
	},
	{
		q: 'Er “shake halvvejs” nok til jævn bagning?',
		a: 'Ofte ja på små ens stykker. Store uens stykker kan kræve at du vender dem manuelt eller deler i to kørsler.',
	},
	{
		q: 'Kan jeg genbruge forvarmning mellem to batch?',
		a: 'Ja — anden batch er ofte lidt hurtigere fordi apparatet allerede er varmt. Tjek alligevel et minut før sidste gang.',
	},
	{
		q: 'Hjælper det at skrue temperatur op når jeg overfylder?',
		a: 'Sjældent god idé: du risikerer mørk yderside og røg fra dryppende fedt uden at midten bliver ensartet. Reducer mængde i stedet.',
	},
	{
		q: 'Hvad med frossen mad og større mængder?',
		a: 'Start med ét lag som i frossen-mad-guiden — fugt frigives hurtigt; overfyldning gør dampproblemet værre. Del portion eller forlæng i to hold med kort pause.',
	},
];

const breadcrumbJson = {
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Forside', item: `${SITE_URL}/` },
		{ '@type': 'ListItem', position: 2, name: 'Guides', item: `${SITE_URL}/guides` },
		{ '@type': 'ListItem', position: 3, name: 'Kapacitet og damp', item: pageUrl },
	],
};

const webPageJson = {
	'@type': 'WebPage',
	'@id': `${pageUrl}#webpage`,
	url: pageUrl,
	name: title.replace(` | ${SITE_NAME}`, ''),
	description,
	inLanguage: 'da-DK',
	isPartOf: { '@id': `${SITE_URL}/#website` },
	datePublished: published,
	dateModified: modified,
};

const articleJson = {
	'@type': 'Article',
	headline: 'Kapacitet, damp og batch i airfryer',
	description,
	image: ogImage,
	inLanguage: 'da-DK',
	datePublished: published,
	dateModified: modified,
	author: { '@id': `${SITE_URL}/#organization` },
	publisher: { '@id': `${SITE_URL}/#organization` },
	mainEntityOfPage: { '@id': `${pageUrl}#webpage` },
};

const faqJson = {
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.q,
		acceptedAnswer: { '@type': 'Answer', text: item.a },
	})),
};

const jsonLd = [
	ORGANIZATION_JSON as Record<string, unknown>,
	webPageJson,
	articleJson,
	breadcrumbJson,
	faqJson,
];
---

<BaseLayout
	title={title}
	{description}
	{canonicalPath}
	ogImage={ogImage}
	ogImageAlt={heroAlt}
	ogImageWidth={heroImageWidth}
	ogImageHeight={heroImageHeight}
	ogType="article"
	articlePublishedTime={published}
	articleModifiedTime={modified}
	{jsonLd}
>
	<section class="section section--tight-top">
		<div class="container">
			<nav class="recipe-breadcrumbs" aria-label="Brødkrummer">
				<a href="/">Forside</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<a href="/guides">Guides</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<span class="recipe-breadcrumbs-current">Kapacitet og damp</span>
			</nav>

			<div class="guide-hero">
				<img
					src={heroImagePath}
					alt={heroAlt}
					width={heroImageWidth}
					height={heroImageHeight}
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
			</div>

			<article class="prose guide-prose">
				<p class="section-kicker guide-article-kicker">Teknik</p>
				<h1>Kapacitet, damp og batch i airfryer</h1>
				<p class="guide-lead">
					Airfryer er ikke “magisk større indvendig” end den kurv du ser. Når du presser mad sammen, skifter
					fysikken: i stedet for <strong>tør, hurtig luft</strong> sidder maden i et mikroklima af{' '}
					<strong>damp</strong> — og så ender pommes, panering og grønt med at blive bløde, selvom tiden er
					“rigtig”.
				</p>

				<h2>Hvorfor ét lag (næsten) altid vinder</h2>
				<p>
					Varmluft skal kunne <strong>ramme synlige overflader</strong>. Stabler du ting, skygger de for
					hinanden — og det der slipper ud mellem stykkerne er ofte fugt fra maden. Det er princippet bag “ét
					lag” i <a href="/guides/airfryer-for-begyndere">begynderguiden</a> — ikke pedanteri, men sprødhed.
				</p>

				<h2>Tegn på at du har for meget i kurven</h2>
				<ul>
					<li>Pommes eller grøntsager der kommer ud ensartet fugtige uden at få farve.</li>
					<li>Panering der bliver “svampet” selv med olie og fornuftig temperatur.</li>
					<li>Længere tider end opskriften — uden at det bliver bedre (du dampkoger i praksis).</li>
					<li>Mere damp ved åbning end du er vant til — sammenlign med <a href="/guides/frossen-mad-airfryer">frossen mad</a>, hvor fugt frigives hurtigt.</li>
				</ul>

				<h2>Batch uden at ødelægge tempoet</h2>
				<ul>
					<li>
						<strong>Del i to omgange</strong> og hold første batch varmt under låg på en tallerken — kort,
						ikke timer.
					</li>
					<li>
						<strong>Anden batch</strong> er ofte lidt hurtigere; tjek et minut tidligere.
					</li>
					<li>
						<strong>Ryst halvvejs</strong> så små stykker bytter plads — samme vane som ved{' '}
						<a href="/opskrifter/airfryer-pomfritter">pomfritter</a>.
					</li>
				</ul>

				<h2>Strategi til familieportioner</h2>
				<p>
					Brug dobbeltkurv eller to zoner hvis du har det — ellers tænk “samme måltid, to serier”. Det er ofte
					hurtigere end at kæmpe én overfyldt kurv i uendelighed. Til{' '}
					<a href="/guides/genopvarmning-i-airfryer">genopvarmning</a> gælder samme logik: for meget på én
					gang giver damp og slatne kanter.
				</p>

				<h2>Hvordan olie og marinader spiller ind</h2>
				<p>
					For meget væske på overfladen forstærker damp og kan også dryppe ned og genere febrilsk røg — hold
					olie som <a href="/guides/sproed-med-mindre-olie">tynde lag</a>, og undgå at marinaden ligger i en
					dyb sø i bunden af kurven.
				</p>

				<p class="guide-back">
					<a href="/guides">← Tilbage til alle guides</a>
				</p>

				<GuidePriceRunnerSpotlight guideId="kapacitet-damp-batch-airfryer" />

				<h2>Ofte stillede spørgsmål</h2>
				<div class="guide-faq">
					{
						faqItems.map((item) => (
							<details>
								<summary>{item.q}</summary>
								<p>{item.a}</p>
							</details>
						))
					}
				</div>
			</article>
		</div>
	</section>
</BaseLayout>

<style>
	.guide-hero {
		max-width: 48rem;
		margin-bottom: var(--space-8);
		border-radius: var(--radius-xl);
		overflow: hidden;
		border: 1px solid rgb(0 0 0 / 6%);
		box-shadow: var(--shadow-md);
	}
	.guide-hero img {
		display: block;
		width: 100%;
		height: auto;
		vertical-align: middle;
	}
	.guide-prose {
		max-width: 48rem;
	}
	.guide-article-kicker {
		margin-bottom: var(--space-2);
	}
	.guide-lead {
		font-size: 1.08rem;
		line-height: 1.65;
	}
	.guide-back {
		margin-top: var(--space-8);
	}
	.guide-faq {
		margin-top: var(--space-6);
	}
	.guide-faq details {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--space-4) var(--space-5);
		margin-bottom: var(--space-3);
		background: var(--color-surface);
	}
	.guide-faq summary {
		font-weight: 650;
		cursor: pointer;
		color: var(--color-text);
	}
	.guide-faq details p {
		margin: var(--space-4) 0 0;
		color: var(--color-muted);
		line-height: 1.65;
	}
</style>
