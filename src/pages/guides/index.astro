---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ORGANIZATION_JSON, SITE_NAME, SITE_URL } from '../../consts';

const title = `Guides | ${SITE_NAME}`;
const description =
	'Praktiske guides til airfryer: kom godt i gang med temperatur, tid og gode vaner – og find nemt videre til opskrifter.';

const jsonLd = [
	ORGANIZATION_JSON as Record<string, unknown>,
	{
		'@type': 'WebPage',
		'@id': `${SITE_URL}/guides#webpage`,
		url: `${SITE_URL}/guides`,
		name: title,
		description,
		inLanguage: 'da-DK',
		isPartOf: { '@id': `${SITE_URL}/#website` },
	},
];
---

<BaseLayout title={title} description={description} canonicalPath="/guides" jsonLd={jsonLd}>
	<section class="section section--tight-top">
		<div class="container">
			<nav class="recipe-breadcrumbs" aria-label="Brødkrummer">
				<a href="/">Forside</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<span class="recipe-breadcrumbs-current">Guides</span>
			</nav>

			<div class="section-head">
				<p class="section-kicker">Guides</p>
				<h1 class="recipe-title">Guides til airfryer</h1>
				<p>
					Korte, praktiske artikler der supplerer vores <a href="/opskrifter">opskrifter</a>: gode
					vaner, temperatur og fejl, mange undgår første gang.
				</p>
			</div>

			<ul class="guide-list" role="list">
				<li>
					<a class="guide-card" href="/guides/airfryer-for-begyndere">
						<span class="guide-card-kicker">Kom godt i gang</span>
						<span class="guide-card-title">Airfryer for begyndere</span>
						<span class="guide-card-desc">
							Temperatur, tid, forvarmning, ét lag i kurven og typiske fejl – så du rammer god
							resultat fra start.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/ovn-til-airfryer-tid-temperatur">
						<span class="guide-card-kicker">Teknik</span>
						<span class="guide-card-title">Fra ovn til airfryer: tid og temperatur</span>
						<span class="guide-card-desc">
							Konverter ovnopskrifter med fornuftige tommelfingerregler: tid, temperatur, forvarmning og
							hvordan du tjekker uden at brænde ydersiden.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/hvad-kan-man-lave-i-en-airfryer">
						<span class="guide-card-kicker">Inspiration</span>
						<span class="guide-card-title">Hvad kan man lave i en airfryer?</span>
						<span class="guide-card-desc">
							Kategorier fra kød og fisk til grønt, vegetar, snacks og bagning — med links til
							konkrete opskrifter og korte tips om begrænsninger.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/hvilken-airfryer">
						<span class="guide-card-kicker">Køb og valg</span>
						<span class="guide-card-title">Hvilken airfryer skal du vælge?</span>
						<span class="guide-card-desc">
							Kurvstørrelse, familie, én kurv vs. dobbelt zone og plads på bordet – plus hvordan du
							bruger shop-filtrene.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/tilbehoer-til-airfryer">
						<span class="guide-card-kicker">Udstyr</span>
						<span class="guide-card-title">Tilbehør til airfryer</span>
						<span class="guide-card-desc">
							Papir, silikone, spray, rist og spyd: hvad der lønner sig, og hvad du roligt kan vente
							med.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/rengoering-lugt-airfryer">
						<span class="guide-card-kicker">Vedligeholdelse</span>
						<span class="guide-card-title">Rengøring og lugt i airfryer</span>
						<span class="guide-card-desc">
							Rutiner efter brug, grundrens af kurv og bund, filter og hvad du typisk skal undgå for at
							bevare belægning.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/fejlfinding-roeg-fedt-brandalarm">
						<span class="guide-card-kicker">Sikkerhed</span>
						<span class="guide-card-title">Fejlfinding: røg, fedt og brandalarm</span>
						<span class="guide-card-desc">
							Når det ryger eller alarmen reagerer: damp vs. fedt, hvad der ofte er normalt — og hvornår du
							skal stoppe og forebygge næste gang.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/sproed-med-mindre-olie">
						<span class="guide-card-kicker">Teknik</span>
						<span class="guide-card-title">Sprød med mindre olie</span>
						<span class="guide-card-desc">
							Spray vs. pensel, panering uden sort skorpe, og hvorfor luft og ét lag slår ekstra
							oliesjat.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/kapacitet-damp-batch-airfryer">
						<span class="guide-card-kicker">Teknik</span>
						<span class="guide-card-title">Kapacitet, damp og batch i airfryer</span>
						<span class="guide-card-desc">
							Undgå bløde pommes og panering: hvorfor overfyldt kurv giver damp, og hvordan du fordeler i
							to hold uden at ødelægge sprødhed.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/kernetemperatur-airfryer">
						<span class="guide-card-kicker">Sikker mad</span>
						<span class="guide-card-title">Kernetemperatur i airfryer</span>
						<span class="guide-card-desc">
							Mål rigtigt på kylling, kød og fisk: typiske temperaturer, hviletid og hvorfor gylden farve
							ikke er nok.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/jul-i-airfryer">
						<span class="guide-card-kicker">Sæson</span>
						<span class="guide-card-title">Jul i airfryer</span>
						<span class="guide-card-desc">
							Ovn vs. airfryer til steger, tidsplan når pladsen er trang, faldgruber med svær og fedt
							– plus opskrifter til julebordet.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/frossen-mad-airfryer">
						<span class="guide-card-kicker">Hverdag</span>
						<span class="guide-card-title">Frossen mad i airfryer</span>
						<span class="guide-card-desc">
							Undgå damp og bløde pommes: optø, ét lag, ryst og tider der matcher frost – med links til
							konkrete opskrifter.
						</span>
					</a>
				</li>
				<li>
					<a class="guide-card" href="/guides/genopvarmning-i-airfryer">
						<span class="guide-card-kicker">Hverdag</span>
						<span class="guide-card-title">Genopvarmning i airfryer</span>
						<span class="guide-card-desc">
							Rester og takeaway uden slat pizzabund: temperatur, korte intervaller og hvornår mikro
							stadig er smartest.
						</span>
					</a>
				</li>
			</ul>
		</div>
	</section>
</BaseLayout>

<style>
	.guide-list {
		list-style: none;
		margin: 0;
		padding: 0;
		max-width: 44rem;
	}
	.guide-list li + li {
		margin-top: var(--space-4);
	}
	.guide-card {
		display: block;
		padding: var(--space-6) var(--space-7);
		border-radius: var(--radius-xl);
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		box-shadow: var(--shadow-xs);
		text-decoration: none;
		color: inherit;
		transition:
			border-color 0.15s ease,
			box-shadow 0.15s ease;
	}
	.guide-card:hover {
		border-color: rgb(180 83 9 / 28%);
		box-shadow: var(--shadow-sm);
	}
	.guide-card-kicker {
		display: block;
		font-size: 0.8125rem;
		font-weight: 650;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--color-accent-dark);
		margin-bottom: var(--space-2);
	}
	.guide-card-title {
		display: block;
		font-family: var(--font-display);
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--color-text);
		margin-bottom: var(--space-3);
	}
	.guide-card-desc {
		display: block;
		font-size: 1.02rem;
		line-height: 1.6;
		color: var(--color-muted);
	}
</style>
