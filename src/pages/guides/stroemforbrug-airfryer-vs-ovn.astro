---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuidePriceRunnerSpotlight from '../../components/GuidePriceRunnerSpotlight.astro';
import { ORGANIZATION_JSON, SITE_NAME, SITE_URL } from '../../consts';

const canonicalPath = '/guides/stroemforbrug-airfryer-vs-ovn';
const pageUrl = new URL(canonicalPath, SITE_URL).toString();
const title = `Strømforbrug: airfryer vs ovn – hvad koster det og hvornår lønner det sig? | ${SITE_NAME}`;
const description =
	'Airfryer versus ovn strøm: små kubikmeter varmes hurtigt, mens stor ovn bruger mere kWh i forvarmning og luft fyld — hvornår kurv-maskinen reelt matcher en el-ovn i prisen pr. aftensmad, uden fanboys.';

const published = '2026-04-09T12:00:00.000Z';
const modified = '2026-05-24T16:00:00.000Z';

const heroImagePath = '/images/guides/stroemforbrug-airfryer-vs-ovn.png';
const heroImageWidth = 1024;
const heroImageHeight = 818;
const heroAlt =
	'Airfryer og ovn i køkken med naturligt dagslys — illustration til sammenligning af strømforbrug';
const ogImage = new URL(heroImagePath, SITE_URL).toString();

const faqItems = [
	{
		q: 'Bruger airfryer mindre strøm end ovnen?',
		a: 'Ofte ja til små portioner og korte programmer, fordi du opvarmer et lille rum og sommetider sparer lang forvarmning. Til store fade og lang bagetid kan en ovn med god isolering stadig være konkurrencedygtig pr. kg mad.',
	},
	{
		q: 'Hvordan regner jeg kWh?',
		a: 'kWh ≈ (effekt i kW) × (tid i timer). Eksempel: 1,5 kW i 20 minutter = 1,5 × (20/60) ≈ 0,5 kWh. Din elaftale bestemmer prisen.',
	},
	{
		q: 'Tæller forvarmning med?',
		a: 'Ja. Airfryer forvarmer ofte hurtigt (2–4 min). Almindelig ovn kan bruge 10–15+ min på fuld effekt før du lægger fadet ind — det tæller på regningen.',
	},
	{
		q: 'Er en større airfryer dyrere i drift?',
		a: 'Typisk højere maksimal effekt, men du laver ofte mere i ét lag. Sammenlign altid med hvad du rent faktisk bruger i hverdagen.',
	},
	{
		q: 'Hvad med mikrobølge?',
		a: 'Til pure opvarmning af små mængder væske eller rester er mikro ofte mest effektiv i kWh. Airfryer vinder på sprød tekstur, ikke nødvendigvis på den laveste kWh ved alt.',
	},
	{
		q: 'Kan elpriser gøre airfryer til et must?',
		a: 'Den kan hjælpe ved korte sessioner, men dit samlede elforbrug afhænger også af køleskab, elbil og varme. Luft-til-luft-varmepumpe m.m. dominere ofte mere end airfryer.',
	},
];

const breadcrumbJson = {
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Forside', item: `${SITE_URL}/` },
		{ '@type': 'ListItem', position: 2, name: 'Guides', item: `${SITE_URL}/guides` },
		{ '@type': 'ListItem', position: 3, name: 'Strømforbrug', item: pageUrl },
	],
};

const webPageJson = {
	'@type': 'WebPage',
	'@id': `${pageUrl}#webpage`,
	url: pageUrl,
	name: title.replace(` | ${SITE_NAME}`, ''),
	description,
	inLanguage: 'da-DK',
	isPartOf: { '@id': `${SITE_URL}/#website` },
	datePublished: published,
	dateModified: modified,
};

const articleJson = {
	'@type': 'Article',
	headline: 'Strømforbrug: airfryer vs ovn',
	description,
	image: ogImage,
	inLanguage: 'da-DK',
	datePublished: published,
	dateModified: modified,
	author: { '@id': `${SITE_URL}/#organization` },
	publisher: { '@id': `${SITE_URL}/#organization` },
	mainEntityOfPage: { '@id': `${pageUrl}#webpage` },
};

const faqJson = {
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.q,
		acceptedAnswer: { '@type': 'Answer', text: item.a },
	})),
};

const jsonLd = [
	ORGANIZATION_JSON as Record<string, unknown>,
	webPageJson,
	articleJson,
	breadcrumbJson,
	faqJson,
];
---

<BaseLayout
	title={title}
	{description}
	{canonicalPath}
	ogImage={ogImage}
	ogImageAlt={heroAlt}
	ogImageWidth={heroImageWidth}
	ogImageHeight={heroImageHeight}
	ogType="article"
	articlePublishedTime={published}
	articleModifiedTime={modified}
	{jsonLd}
>
	<section class="section section--tight-top">
		<div class="container">
			<nav class="recipe-breadcrumbs" aria-label="Brødkrummer">
				<a href="/">Forside</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<a href="/guides">Guides</a>
				<span class="recipe-breadcrumbs-sep" aria-hidden="true">/</span>
				<span class="recipe-breadcrumbs-current">Strømforbrug</span>
			</nav>

			<div class="guide-hero">
				<img
					src={heroImagePath}
					alt={heroAlt}
					width={heroImageWidth}
					height={heroImageHeight}
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
			</div>

			<article class="prose guide-prose">
				<p class="section-kicker guide-article-kicker">Økonomi</p>
				<h1>Strømforbrug: airfryer vs ovn</h1>
				<p class="guide-lead">
					<strong>Watt på etiketten</strong> fortæller ikke hele historien. Det der betyder noget på
					elregningen er, hvor mange <strong>kWh</strong> du bruger pr. gang — og det afhænger af effekt
					<em>og</em> tid, inklusive forvarmning, og hvor meget mad du laver ad gangen.
				</p>

				<h2>Sådan tænker du kWh i praksis</h2>
				<p>
					Forenklet: <strong>kWh ≈ kW × timer</strong>. En airfryer mærket omkring 1,4–1,8 kW i 25
					minutters samlet drift (inkl. kort opvarmning) lander ofte omkring <strong>0,6–0,75 kWh</strong>.
					En ovn på 2–2,5 kW i 35–50 minutter med længere forvarmning kan ende højere for små
					portioner — men billigere til ét stort fad der fylder hele familien.
				</p>

				<h2>Hvornår airfryer ofte vinder i “små opgaver”</h2>
				<ul>
					<li>
						Du laver <strong>1–2 portioner</strong> og kan nøjes med kort forvarmning eller ingen hvis
						opskriften tillader det.
					</li>
					<li>
						Du vil have <strong>sprød yderside</strong> uden at tænde ovnen i lang tid — fx
						<a href="/guides/sproed-med-mindre-olie">lækker skorpe</a>.
					</li>
					<li>
						Sommer og <strong>varmt køkken</strong>: mindre overskud af varme fra en lille kurv end fra ovn
						på 200+ °C i lang tid.
					</li>
				</ul>

				<h2>Hvornår ovnen stadig giver mening</h2>
				<ul>
					<li>
						<strong>Stort brad</strong>, flere plader eller dybe fad med sauce der skal have ro i 45+
						minutter.
					</li>
					<li>
						Flere retter <strong>samtidig</strong> — airfryer har typisk én kurv ad gangen (medmindre du
						har dobbelt zone).
					</li>
					<li>
						Opskrifter der <strong>kræver lav og lang</strong> bagning i hele ovnens volumen.
					</li>
				</ul>

				<h2>Brug de guides du allerede har</h2>
				<p>
					<strong>Kort varm opstart</strong> og læs om tid/temperatur i
					<a href="/guides/ovn-til-airfryer-tid-temperatur">fra ovn til airfryer-guiden</a>. Undgå damp og
					forlænget tid ved at respektere
					<a href="/guides/kapacitet-damp-batch-airfryer">ét lag og batch</a> — ellers tror du fejlagtigt,
					at airfryer “sluger strøm”, når problemet er overfyldt kurv.
				</p>

				<p class="guide-back">
					<a href="/guides">← Tilbage til alle guides</a>
				</p>

				<GuidePriceRunnerSpotlight guideId="stroemforbrug-airfryer-vs-ovn" />

				<h2>Ofte stillede spørgsmål</h2>
				<div class="guide-faq">
					{
						faqItems.map((item) => (
							<details>
								<summary>{item.q}</summary>
								<p>{item.a}</p>
							</details>
						))
					}
				</div>
			</article>
		</div>
	</section>
</BaseLayout>

<style>
	.guide-hero {
		max-width: 48rem;
		margin-bottom: var(--space-8);
		border-radius: var(--radius-xl);
		overflow: hidden;
		border: 1px solid rgb(0 0 0 / 6%);
		box-shadow: var(--shadow-md);
	}
	.guide-hero img {
		display: block;
		width: 100%;
		height: auto;
		vertical-align: middle;
	}
	.guide-prose {
		max-width: 48rem;
	}
	.guide-article-kicker {
		margin-bottom: var(--space-2);
	}
	.guide-lead {
		font-size: 1.08rem;
		line-height: 1.65;
	}
	.guide-back {
		margin-top: var(--space-8);
	}
	.guide-faq {
		margin-top: var(--space-6);
	}
	.guide-faq details {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--space-4) var(--space-5);
		margin-bottom: var(--space-3);
		background: var(--color-surface);
	}
	.guide-faq summary {
		font-weight: 650;
		cursor: pointer;
		color: var(--color-text);
	}
	.guide-faq details p {
		margin: var(--space-4) 0 0;
		color: var(--color-muted);
		line-height: 1.65;
	}
</style>
