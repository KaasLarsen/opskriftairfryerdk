---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import SiteSearch from '../components/SiteSearch.astro';
import { getCollection } from 'astro:content';
import { HOME_FEATURED_GUIDES, HOME_FEATURED_REVIEW_IDS } from '../data/homeFeatured';
import { findShopProductByProductUrl } from '../lib/shopProductsFromJson';
import { DEFAULT_DESCRIPTION, ORGANIZATION_JSON, SITE_NAME, SITE_TAGLINE, SITE_URL } from '../consts';

const allRecipes = await getCollection('recipes');
const allReviews = await getCollection('airfryerReviews');
const reviewCount = allReviews.length;

const reviewById = new Map(allReviews.map((r) => [r.id, r]));
const featuredReviews = HOME_FEATURED_REVIEW_IDS.map((id) => {
	const r = reviewById.get(id);
	if (!r) return null;
	const p = findShopProductByProductUrl(r.data.shopProductUrl);
	const thumb = r.data.heroImage ?? p?.imageUrl ?? null;
	const brand = (r.data.brandLabel ?? p?.brand ?? '').trim();
	return {
		id: r.id,
		href: `/anmeldelser/${r.id}`,
		title: r.data.title,
		description: r.data.description,
		rating: r.data.rating,
		thumb,
		thumbAlt: r.data.heroAlt ?? r.data.title,
		brand,
	};
}).filter(Boolean) as {
	id: string;
	href: string;
	title: string;
	description: string;
	rating?: number;
	thumb: string | null;
	thumbAlt: string;
	brand: string;
}[];
const featuredPool = allRecipes
	.filter((r) => r.data.featured === true)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = featuredPool.slice(0, 5);
const featuredIds = new Set(featured.map((r) => r.id));

const popular = allRecipes
	.filter((r) => r.data.featured === true && !featuredIds.has(r.id))
	.sort(
		(a, b) =>
			(b.data.updatedDate ?? b.data.pubDate).valueOf() -
			(a.data.updatedDate ?? a.data.pubDate).valueOf(),
	)
	.slice(0, 6);

/** Kurateret forår: grønt, fisk og let tilbehør — rækkefølge = ønsket prioritering på forsiden */
const springIdsOrdered = [
	'airfryer-asparges',
	'airfryer-aeggekage-asparges-bacon',
	'airfryer-groentsagsmix',
	'airfryer-laks',
	'airfryer-bagekartofler',
	'airfryer-honning-guleroedder',
	'airfryer-blomkaal',
	'airfryer-courgette-parmesan-fritter',
	'airfryer-jordskokke-rosmarin-citron',
	'airfryer-soede-kartofler',
];
const recipeById = new Map(allRecipes.map((r) => [r.id, r]));
const spring = [];
for (const id of springIdsOrdered) {
	const r = recipeById.get(id);
	if (r) spring.push(r);
	if (spring.length >= 6) break;
}

const quick = allRecipes
	.filter((r) => r.data.prepMinutes + r.data.cookMinutes <= 30)
	.sort((a, b) => a.data.prepMinutes + a.data.cookMinutes - (b.data.prepMinutes + b.data.cookMinutes))
	.slice(0, 6);

const site = Astro.site ?? new URL(SITE_URL);
const ogImage = new URL('/images/hero-forside.png', site).toString();

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		ORGANIZATION_JSON,
		{
			'@type': 'WebSite',
			'@id': `${SITE_URL}/#website`,
			url: SITE_URL,
			name: SITE_NAME,
			description: DEFAULT_DESCRIPTION,
			inLanguage: 'da-DK',
			publisher: { '@id': `${SITE_URL}/#organization` },
		},
	],
};
---

<BaseLayout
	title={`${SITE_NAME} – ${SITE_TAGLINE}`}
	description={DEFAULT_DESCRIPTION}
	canonicalPath="/"
	ogImage={ogImage}
	jsonLd={jsonLd['@graph'] as Record<string, unknown>[]}
>
	<section class="hero">
		<div class="container hero-grid">
			<div class="hero-copy">
				<span class="hero-badge">Nem hverdag • Tydelige tider</span>
				<h1>Nemme airfryer-opskrifter til hverdagen</h1>
				<p class="hero-lead">
					Tydelige tider, realistiske temperaturer og trin du kan følge, også når det går stærkt.
					Her samler vi opskrifter, der er lige til at gå til.
				</p>
				<div class="hero-search">
					<SiteSearch variant="hero" />
				</div>
				<div class="hero-actions">
					<a class="btn btn-primary" href="/opskrifter">Se alle opskrifter</a>
					<a class="btn btn-ghost" href="/guides">Guides til airfryer</a>
					<a class="btn btn-ghost" href="/anmeldelser">
						Airfryer-anmeldelser ({reviewCount})
					</a>
				</div>
			</div>
			<div class="hero-visual">
				<img
					src="/images/hero-forside.png"
					alt="Airfryer med sprød kylling og kartofler, omringet af grøntsagsmix, laks med salat og dip på rustikt træbord"
					width="1024"
					height="682"
					loading="eager"
					fetchpriority="high"
					decoding="async"
				/>
			</div>
		</div>
	</section>

	{
		featured.length > 0 && (
			<section class="section">
				<div class="container">
					<div class="section-head">
						<p class="section-kicker">Udvalgte opskrifter</p>
						<h2>Start med disse fem hverdagsfavoritter</h2>
						<p>
							Hurtige retter med få ingredienser – gode som aftensmad eller når du vil have styr på
							tid og temperatur.
						</p>
					</div>
					<div class="recipe-grid">
						{featured.map((recipe) => (
							<RecipeCard recipe={recipe} />
						))}
					</div>
				</div>
			</section>
		)
	}

	{
		HOME_FEATURED_GUIDES.length > 0 && (
			<section class="section section--tight-top">
				<div class="container">
					<div class="section-head">
						<p class="section-kicker">Guides</p>
						<h2>Praktiske guides til airfryer</h2>
						<p>
							Korte artikler om temperatur, valg af maskine, hverdag og frys — ud over selve
							opskrifterne. <a href="/guides">Se alle guides</a>
						</p>
					</div>
					<div class="recipe-grid">
						{HOME_FEATURED_GUIDES.map((g) => (
							<a class="recipe-card" href={g.href}>
								<div class="recipe-card-image">
									<img
										src={g.image}
										alt={g.imageAlt}
										width="640"
										height="400"
										loading="lazy"
										decoding="async"
									/>
								</div>
								<div class="recipe-card-body">
									<div class="recipe-card-badges">
										<span class="recipe-card-badge">{g.kicker}</span>
										<span class="recipe-card-badge recipe-card-badge--muted">Guide</span>
									</div>
									<h3>{g.title}</h3>
									<p>{g.description}</p>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		)
	}

	{
		spring.length > 0 && (
			<section class="section section--tight-top">
				<div class="container">
					<div class="section-head">
						<p class="section-kicker">Sæson</p>
						<h2>Forår i airfryer</h2>
						<p>
							Grønt, lettere fisk og tilbehør der passer til lysere aftener — også når det skal gå
							stærkt.
						</p>
					</div>
					<div class="recipe-grid">
						{spring.map((recipe) => (
							<RecipeCard recipe={recipe} />
						))}
					</div>
				</div>
			</section>
		)
	}

	{
		popular.length > 0 && (
			<section class="section section--tight-top">
				<div class="container">
					<div class="section-head">
						<p class="section-kicker">Populært</p>
						<h2>Mest populære lige nu</h2>
						<p>Opskrifter vi fremhæver mest, og som besøgende typisk starter med.</p>
					</div>
					<div class="recipe-grid">
						{popular.map((recipe) => (
							<RecipeCard recipe={recipe} />
						))}
					</div>
				</div>
			</section>
		)
	}

	<section class="section section--tight-top">
		<div class="container">
			<div class="section-head">
				<p class="section-kicker">Hurtigt</p>
				<h2>Under 30 minutter</h2>
				<p>Når det skal gå stærkt, men stadig smage af noget.</p>
			</div>
			<div class="recipe-grid">
				{quick.map((recipe) => <RecipeCard recipe={recipe} />)}
			</div>
		</div>
	</section>

	{
		featuredReviews.length > 0 && (
			<section class="section section--tight-top">
				<div class="container">
					<div class="section-head">
						<p class="section-kicker">Anmeldelser</p>
						<h2>Udvalgte airfryer-anmeldelser</h2>
						<p>
							Vurderinger med fordele, ulemper og hvem modellen passer til — plus link til pris hos
							forhandler.
							<a href="/anmeldelser"> Se alle {reviewCount} anmeldelser</a>
						</p>
					</div>
					<div class="recipe-grid">
						{featuredReviews.map((rev) => (
							<a class="recipe-card" href={rev.href}>
								<div
									class:list={['recipe-card-image', !rev.thumb && 'recipe-card-image--placeholder']}
								>
									{rev.thumb ? (
										<img
											src={rev.thumb}
											alt={rev.thumbAlt}
											width="640"
											height="400"
											loading="lazy"
											decoding="async"
										/>
									) : (
										<div class="recipe-placeholder-inner">
											<span class="recipe-placeholder-label">Billede på vej</span>
										</div>
									)}
								</div>
								<div class="recipe-card-body">
									<div class="recipe-card-badges">
										{rev.brand ? (
											<span class="recipe-card-badge">{rev.brand}</span>
										) : (
											<span class="recipe-card-badge">Anmeldelse</span>
										)}
										{rev.rating != null ? (
											<span class="recipe-card-badge recipe-card-badge--muted">
												{rev.rating}/5 stjerner
											</span>
										) : null}
									</div>
									<h3>{rev.title}</h3>
									<p>{rev.description}</p>
								</div>
							</a>
						))}
					</div>
				</div>
			</section>
		)
	}
</BaseLayout>
