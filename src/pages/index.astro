---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';
import { DEFAULT_DESCRIPTION, ORGANIZATION_JSON, SITE_NAME, SITE_TAGLINE, SITE_URL } from '../consts';

const allRecipes = await getCollection('recipes');
const featured = allRecipes
	.filter((r) => r.data.featured !== false)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const site = Astro.site ?? new URL(SITE_URL);
const ogImage = new URL('/og-default.svg', site).toString();

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		ORGANIZATION_JSON,
		{
			'@type': 'WebSite',
			'@id': `${SITE_URL}/#website`,
			url: SITE_URL,
			name: SITE_NAME,
			description: DEFAULT_DESCRIPTION,
			inLanguage: 'da-DK',
			publisher: { '@id': `${SITE_URL}/#organization` },
		},
	],
};
---

<BaseLayout
	title={`${SITE_NAME} – ${SITE_TAGLINE}`}
	description={DEFAULT_DESCRIPTION}
	canonicalPath="/"
	ogImage={ogImage}
	jsonLd={jsonLd['@graph'] as Record<string, unknown>[]}
>
	<section class="hero">
		<div class="container hero-grid">
			<div>
				<span class="hero-badge">Nem hverdag • Tydelige tider</span>
				<h1>Nemme airfryer-opskrifter til hverdagen</h1>
				<p class="hero-lead">
					Tydelige tider, realistiske temperaturer og trin du kan følge, også når det går stærkt.
					Her samler vi opskrifter, der er lige til at gå til.
				</p>
				<div class="hero-actions">
					<a class="btn btn-primary" href="/opskrifter">Se alle opskrifter</a>
				</div>
			</div>
			<div
				class="hero-visual hero-visual--placeholder"
				role="img"
				aria-label="Plads til foto – kommer snart"
			>
				<span class="hero-placeholder-label">Foto til forsiden kommer snart</span>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-head">
				<p class="section-kicker">Udvalgte opskrifter</p>
				<h2>Start med disse fem hverdagsfavoritter</h2>
				<p>
					Hurtige retter med få ingredienser – gode som aftensmad eller når du vil have styr på
					tid og temperatur.
				</p>
			</div>
			<div class="recipe-grid">
				{featured.map((recipe) => <RecipeCard recipe={recipe} />)}
			</div>
		</div>
	</section>
</BaseLayout>
