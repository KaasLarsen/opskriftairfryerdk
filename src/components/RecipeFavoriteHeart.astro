---
interface Props {
	recipeId: string;
	/** hero = over billede på opskriftside; inline = ved siden af badges på kort */
	variant?: 'hero' | 'inline';
}

const { recipeId, variant = 'hero' } = Astro.props;
const configured =
	Boolean(import.meta.env.PUBLIC_SUPABASE_URL?.trim()) &&
	Boolean(import.meta.env.PUBLIC_SUPABASE_ANON_KEY?.trim());

const isHero = variant === 'hero';
const btnClass = isHero
	? 'recipe-favorite-btn recipe-favorite-btn--hero'
	: 'recipe-favorite-btn recipe-favorite-btn--inline';
const svgClass = isHero ? 'recipe-favorite-svg recipe-favorite-svg--hero' : 'recipe-favorite-svg';
const iconSize = isHero ? 28 : 22;
---

{
	configured && (
		<div class={isHero ? 'recipe-favorite-wrap' : 'recipe-favorite-inline'}>
			<button
				type="button"
				class:list={[btnClass]}
				data-recipe-favorite
				data-recipe-id={recipeId}
				aria-pressed="false"
				aria-label="Gem opskrift"
			>
				<svg
					class:list={[svgClass]}
					width={iconSize}
					height={iconSize}
					viewBox="0 0 24 24"
					aria-hidden="true"
					focusable="false"
				>
					<path
						class="recipe-favorite-path"
						d="M12 20.35l-1.45-1.32C5.4 14.36 2 11.28 2 7.5 2 5.42 3.42 4 5.5 4c1.74 0 3.41 1.01 4.25 2.59h.05C10.59 5.01 12.26 4 14 4c2.08 0 3.5 1.42 3.5 3.5 0 3.78-3.4 6.86-8.55 11.54L12 20.35z"
						fill="none"
						stroke="currentColor"
						stroke-width="1.75"
						stroke-linejoin="round"
					/>
				</svg>
			</button>
		</div>
	)
}
