---
import { SITE_NAME } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="container footer-grid">
		<div>
			<p class="footer-brand">{SITE_NAME}</p>
			<p class="footer-tagline">
				Nemme airfryer-opskrifter med tydelige tider, temperaturer og trin-for-trin – til hverdagen.
			</p>
		</div>
		<div class="footer-col">
			<h4>Menu</h4>
			<ul>
				<li><a href="/">Forside</a></li>
				<li><a href="/opskrifter">Alle opskrifter</a></li>
				<li><a href="/shop">Shop</a></li>
				<li><a href="/om">Om os</a></li>
				<li><a href="/kontakt">Kontakt</a></li>
			</ul>
		</div>
	</div>
	<div class="container footer-bottom">
		<p class="footer-legal">
			&copy; {year} {SITE_NAME}. Indhold må deles med tydeligt link tilbage til kilden.
		</p>
	</div>
</footer>
