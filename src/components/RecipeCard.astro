---
import type { CollectionEntry } from 'astro:content';

interface Props {
	recipe: CollectionEntry<'recipes'>;
}

const { recipe } = Astro.props;
const {
	title,
	description,
	heroImage,
	heroAlt,
	prepMinutes,
	cookMinutes,
	category,
} = recipe.data;
const total = prepMinutes + cookMinutes;
const href = `/opskrifter/${recipe.id}`;
---

<a class="recipe-card" href={href}>
	<div class:list={['recipe-card-image', !heroImage && 'recipe-card-image--placeholder']}>
		{
			heroImage ? (
				<img
					src={heroImage}
					alt={heroAlt ?? title}
					width="640"
					height="400"
					loading="lazy"
					decoding="async"
				/>
			) : (
				<div class="recipe-placeholder-inner">
					<span class="recipe-placeholder-label">Billede på vej</span>
				</div>
			)
		}
	</div>
	<div class="recipe-card-body">
		<div class="recipe-card-badges">
			<span class="recipe-card-badge">{category}</span>
			<span class="recipe-card-badge recipe-card-badge--muted">{total} min i alt</span>
		</div>
		<h3>{title}</h3>
		<div class="recipe-meta-row">
			<span>Forberedelse {prepMinutes} min</span>
			<span>·</span>
			<span>Tilberedning {cookMinutes} min</span>
		</div>
		<p>{description}</p>
	</div>
</a>
