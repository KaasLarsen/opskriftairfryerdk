---
export interface Props {
	/** `hero` = større felt til forsiden; `default` = header */
	variant?: 'default' | 'hero';
}

const { variant = 'default' } = Astro.props;
const suffix = variant === 'hero' ? 'hero' : 'header';
const inputId = `site-search-q-${suffix}`;
const panelId = `site-search-panel-${suffix}`;
const placeholder =
	variant === 'hero'
		? 'Søg efter opskrift eller anmeldelse…'
		: 'Søg opskrifter og anmeldelser…';
---

<div
	class:list={['site-search', variant === 'hero' && 'site-search--hero']}
	data-site-search
>
	<label class="sr-only" for={inputId}>Søg på sitet</label>
	<input
		type="search"
		id={inputId}
		class="site-search-input"
		data-site-search-q
		placeholder={placeholder}
		autocomplete="off"
		spellcheck="false"
		aria-autocomplete="list"
		aria-controls={panelId}
		aria-expanded="false"
	/>
	<div
		id={panelId}
		class="site-search-results"
		data-site-search-panel
		role="listbox"
		hidden
		aria-label="Søgeresultater"
	>
	</div>
</div>
