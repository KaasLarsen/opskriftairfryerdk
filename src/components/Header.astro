---
import { SITE_NAME } from '../consts';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string): boolean {
	if (href === '/') return pathname === '/';
	return pathname === href || pathname.startsWith(`${href}/`);
}
---

<header class="site-header">
	<div class="container header-inner">
		<a class="logo" href="/">{SITE_NAME}</a>
		<nav class="nav" aria-label="Hovednavigation">
			<a
				class="nav-link"
				href="/"
				aria-current={isActive('/') ? 'page' : undefined}>Forside</a
			>
			<a
				class="nav-link"
				href="/opskrifter"
				aria-current={isActive('/opskrifter') ? 'page' : undefined}>Opskrifter</a
			>
			<a class="btn btn-primary btn-nav-cta" href="/opskrifter">Se opskrifter</a>
		</nav>
	</div>
</header>
